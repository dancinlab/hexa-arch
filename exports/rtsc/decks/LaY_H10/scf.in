&control
  ! B08 LaY_H10 — post-relax SCF. MUST read the relaxed celldm(1), celldm(3) + positions from
  !   the vc-relax.out (CELL_PARAMETERS / ATOMIC_POSITIONS final block) BEFORE running this.
  !   The celldm values below are the START guess and are overwritten in the RUNBOOK step.
  ! electron_phonon='simple' needs a DENSE k-mesh for the double-delta EPC integral ->
  !   denser than the relax mesh (16x16x10 tetragonal).
  calculation = 'scf'
  prefix = 'layh10'
  outdir = '/home/aiden/rtsc_layh10/out'
  pseudo_dir = '/home/aiden/rtsc_layh10/pseudo'
  tprnfor = .true.
  tstress = .true.
  verbosity = 'low'
/
&system
  ibrav = 6
  celldm(1) = 6.80
  celldm(3) = 2.00
  nat = 22
  ntyp = 3
  ecutwfc = 90.0
  ecutrho = 720.0
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
/
&electrons
  ! d15 small-gap SCF aids (metallic superhydride + La 4f near E_F).
  conv_thr = 1.0d-12
  mixing_beta = 0.3
  mixing_mode = 'local-TF'
  electron_maxstep = 400
/

ATOMIC_SPECIES
  La 138.905 La.pbe-spfn-rrkjus_psl.1.0.0.UPF
  Y  88.906  Y.pbe-spn-rrkjus_psl.1.0.0.UPF
  H  1.008   H.pbe-rrkjus_psl.1.0.0.UPF
ATOMIC_POSITIONS crystal
  La 0.000000 0.000000 0.000000
  Y  0.000000 0.000000 0.500000
  H  0.250000 0.000000 0.060000
  H  0.000000 0.250000 0.060000
  H  0.750000 0.000000 0.060000
  H  0.000000 0.750000 0.060000
  H  0.250000 0.250000 0.190000
  H  0.750000 0.750000 0.190000
  H  0.250000 0.750000 0.190000
  H  0.750000 0.250000 0.190000
  H  0.500000 0.250000 0.310000
  H  0.250000 0.500000 0.310000
  H  0.250000 0.000000 0.560000
  H  0.000000 0.250000 0.560000
  H  0.750000 0.000000 0.560000
  H  0.000000 0.750000 0.560000
  H  0.250000 0.250000 0.690000
  H  0.750000 0.750000 0.690000
  H  0.250000 0.750000 0.690000
  H  0.750000 0.250000 0.690000
  H  0.500000 0.250000 0.810000
  H  0.250000 0.500000 0.810000
K_POINTS automatic
  16 16 10 0 0 0
