&CONTROL
  calculation = 'scf'
  prefix = 'ceh9'
  outdir = './tmp'
  pseudo_dir = '../pseudo'
  tprnfor = .true.
  tstress = .true.
/
&SYSTEM
  ibrav = 0
  nat = __NAT__
  ntyp = 2
  ecutwfc = 80
  ecutrho = 800
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
/
&ELECTRONS
  conv_thr = 1.0d-12
  mixing_beta = 0.4
  electron_maxstep = 400
/
ATOMIC_SPECIES
  Ce  140.116  Ce.UPF
  H   1.008    H.UPF
