gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "CARLA ScenarioRunner closed-loop AV simulation — Linux pool only · macOS honest-block (g3).",
  "Simulated scenarios are SOTIF-style coverage proxies, NOT real-vehicle road-test data.",
  "absorbed=true requires accredited proving-ground + NHTSA / Euro NCAP test passage (g3 — TÜV / KBA territory).",
]

# --- WIRED: handoff (UNECE / NHTSA type-approval dossier skeleton) ----------
[cell.handoff]
substrate         = python3
