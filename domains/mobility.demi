gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "Scenario library bundle (OpenSCENARIO XML · OpenDRIVE network) skeleton — TEMPLATE bundle.",
  "Real OEM scenario catalogs (NHTSA pre-crash · Euro NCAP test protocols) are reference, NOT vendor data.",
  "measurement_gate = GATE_OPEN permanently — synthesize bundle is not an absorption claim (g3).",
]

# --- WIRED (ROI 17 CARLA · Linux-only): verify ------------------------------
# Existing producer: stdlib/mobility/carla_scenario.py (D61 · macOS hard-
# block — Linux pool only).
[cell.verify]
substrate         = python3
python_candidates = python3.13, python3.12, python3
script            = stdlib/mobility/verify.py
record_kind       = mobility_verify_record
output_dir        = exports/mobility/verify
