# photonic.demi — verb-cell manifest for the PHOTONIC (integrated photonics · waveguide · ring resonator) domain
# SSOT scripts in ~/core/hexa-lang/stdlib/photonic/
# Generic dispatcher: ~/core/hexa-lang/stdlib/cockpit/cellrun.hexa
# Demiurge witness: ActionDispatch → CellrunDispatch.run("photonic", verb)
#
# Format: cellrun.hexa Phase A dialect — [cell.<verb>] section headers.
#
# Citations (anchored — see domains/PHOTONIC.md):
#   - coupled-mode theory (open)
#   - ring-resonator Q/FSR (analytic)
#
# Domain caveat (applies to every cell):
# photonic cells run coupled-mode/analytic resonator models — ALL cells stay GATE_OPEN / absorbed=false (g3) — real
# measurement lives in an accredited lab, not here. cellrun = D72 thin shim.

[cell.specify]
substrate         = hexa
script            = stdlib/photonic/specify.hexa
record_kind       = photonic_specify_record
output_dir        = exports/photonic/specify
required_deps     =
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "PHOTONIC target spec skeleton — TEMPLATE.",
  "real specify output lives in an accredited lab / proprietary solver, not this cell.",
  "measurement_gate = GATE_OPEN permanently — specify scaffolding is not an absorption claim (g3).",
]

[cell.structure]
substrate         = hexa
script            = stdlib/photonic/structure.hexa
record_kind       = photonic_structure_record
output_dir        = exports/photonic/structure
required_deps     =
