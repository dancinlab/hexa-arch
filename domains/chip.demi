# chip.demi — verb-cell manifest for the chip (칩 설계 · deep domain)
# SSOT scripts in ~/core/hexa-lang/stdlib/chip/ (NEW · scripts pending —
# Step 2/3 cascade; this manifest declares the wiring shape only).
# Existing chip substrate (per chip §B / §D): ~/core/hexa-lang/stdlib/yosys/
# (read_verilog · passes · abc_map · liberty · write_sdc · gate_record) +
# SKY130 PDK + ABC — κ-43 chip 도메인 substrate=true (yosys absorbed,
# clean-room phase-a; OpenROAD P&R + Magic DRC honest-gap downstream).
# Sibling: ~/core/hexa-chip/ (ARCH §4.4 hexa-lang sibling).
# Generic dispatcher: ~/core/hexa-lang/stdlib/cockpit/cellrun.hexa
# Demiurge witness: ActionDispatch → CellrunDispatch.run("chip", verb)
#
# Format: cellrun.hexa Phase A dialect — [cell.<verb>] section headers,
# key=value lines, scope_caveats as multi-line [ "...", "..." ] array.
# Required keys per cell: substrate, script, record_kind, output_dir,
# gate_default, absorbed_default.
#
# Script paths are RELATIVE to ~/core/hexa-lang/ (the hexa_lang_root
# tunable, env-overridable via HEXA_CELLRUN_HEXA_LANG_ROOT).
#
# Citations (anchored, not repeated per-cell):
#   - Yosys (YosysHQ, ISC) — open-source RTL synthesis (chip §B absorbed)
#   - ABC (Berkeley · UC Regents) — logic optimization + technology mapping
#   - SKY130 PDK (Google + SkyWater · Apache-2.0) — open-source 130 nm node
#   - IEEE Std 1364-2005 — Verilog synthesizable subset reference
#   - rfc_001_chip_domain.md — chip 7-verb deep map (HANDOFF.md §5)
#
# Domain caveat (applies to every cell): clean-room public-surface
# absorption ONLY — OpenROAD P&R, Magic DRC, OpenSTA signoff, full
# tapeout flow 不在 (chip §D honest-gap roster). 5 reference RTL below
# = small didactic chips, NOT tapeout-ready.

# --- UNWIRED: specify (RTL spec scaffold pending) ----------------------------
# Phase A cellrun.hexa has no explicit `unwired = true` key — these
# cells honest-skip via "script missing" (rc=2) since stdlib/chip/specify.py
# does not yet exist. That IS the honest-gap path until producer lands.
[cell.specify]
substrate         = python3
python_candidates = python3.13, python3.12, python3
script            = stdlib/chip/specify.py
record_kind       = chip_specify_record
output_dir        = exports/chip/specify
required_deps     = python3
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "chip + specify scaffold pending — RTL requirements.json template producer 미작성.",
  "Input candidate: archive/comb/rtl/<name>.v · output: top-module name, port roster, target freq, area budget, PDK target.",
  "domains/chip.md + HANDOFF.md §5 가 SSOT 후보; Python wrapper 가 그것을 record JSON 으로 변환 (~50 line firmware-stub-style).",
]

# --- UNWIRED: structure ------------------------------------------------------
[cell.structure]
substrate         = python3
python_candidates = python3.13, python3.12, python3
script            = stdlib/chip/structure.py
record_kind       = chip_structure_record
output_dir        = exports/chip/structure
required_deps     = python3
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "chip + structure pending — module hierarchy + port graph + clock/reset tree extraction producer 미작성.",
  "stdlib/yosys/read_verilog.hexa (Phase A · κ-43) 가 frontend; structure cell 은 RTLIL → JSON dump 의 cellrun adapter.",
  "networkx module-DAG candidate (router_d{4,6}.v 패턴 reuse).",
]

