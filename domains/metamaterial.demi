# metamaterial.demi — verb-cell manifest for the METAMATERIAL (EM metamaterial · effective index · negative-index) domain
# SSOT scripts in ~/core/hexa-lang/stdlib/metamaterial/
# Generic dispatcher: ~/core/hexa-lang/stdlib/cockpit/cellrun.hexa
# Demiurge witness: ActionDispatch → CellrunDispatch.run("metamaterial", verb)
#
# Format: cellrun.hexa Phase A dialect — [cell.<verb>] section headers.
#
# Citations (anchored — see domains/METAMATERIAL.md):
#   - Pendry split-ring resonator (open)
#   - Smith effective-medium retrieval (open)
#
# Domain caveat (applies to every cell):
# metamaterial cells run effective-medium retrieval + analytic EM — ALL cells stay GATE_OPEN / absorbed=false (g3) — real
# measurement lives in an accredited lab, not here. cellrun = D72 thin shim.

[cell.specify]
substrate         = hexa
script            = stdlib/metamaterial/specify.hexa
record_kind       = metamaterial_specify_record
output_dir        = exports/metamaterial/specify
required_deps     =
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "METAMATERIAL target spec skeleton — TEMPLATE.",
  "real specify output lives in an accredited lab / proprietary solver, not this cell.",
  "measurement_gate = GATE_OPEN permanently — specify scaffolding is not an absorption claim (g3).",
]

[cell.structure]
substrate         = hexa
