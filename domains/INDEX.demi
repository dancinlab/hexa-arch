facets.hostility = "macos-clean"
substrate_ssot = "~/core/hexa-brain/"
keywords = ["뇌", "brain", "신경", "neuro", "인지", "bci", "전극"]

[aura]
label = "청각 웨어러블 BCI"
canvas_mode = "cohort"
