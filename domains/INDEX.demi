# domains/INDEX.demi — demiurge domain SSOT (D83, `.demi` v1)
#
# This is the canonical machine-readable source for the 19-domain graph.
# Cockpit + DemiurgeCLI both load this via DemiParser → DomainLoader.
# To add a domain: add one `[<id>]` section here + create
# `domains/<id>.md` for the narrative (D17 sibling-repo pointer is
# optional via `substrate_ssot`).
#
# Syntax (TOML-풍 section-oriented):
#   - line `[<id>]`        — start a new domain record
#   - `key = value`         — scalar (quoted-string or bare-word)
#   - `key = [a, b, c]`     — list (comma-separated, brackets)
#   - `key.subkey = ...`    — dotted-key for nested facets
#   - `#` to end-of-line    — comment
#   - blank lines OK
#
# Graph (D82): direct prerequisites only; transitive closure computed
# by `DomainGraph.transitiveClosure`. Facets (D82) are multi-tag, NOT
# a partition.

# ─────────────────────────────────────────────────────────────────
# Device tier
# ─────────────────────────────────────────────────────────────────

[chip]
label = "칩 설계"
canvas_mode = "chip"
prerequisites = []
facets.scale = "device"
facets.cluster = ["physical", "engineering"]
facets.hostility = "macos-clean"
keywords = ["칩", "반도체", "chip", "soc", "asic", "프로세서", "cpu", "gpu", "noc"]

[firmware]
label = "펌웨어"
canvas_mode = "cohort"
prerequisites = ["chip"]
facets.scale = "device"
facets.cluster = ["engineering"]
facets.hostility = "macos-clean"
keywords = ["펌웨어", "firmware", "embedded", "mcu", "zephyr", "qemu"]

[sscb]
label = "솔리드스테이트 차단기"
canvas_mode = "cohort"
prerequisites = ["chip", "brain"]
facets.scale = "device"
facets.cluster = ["engineering", "physical"]
facets.hostility = "macos-clean"
keywords = ["차단기", "sscb", "interrupter", "차단"]

[rtsc]
label = "초전도 코일"
canvas_mode = "cohort"
prerequisites = []
facets.scale = "device"
facets.cluster = ["physical"]
facets.hostility = "macos-partial"
substrate_ssot = "~/core/hexa-rtsc/"
keywords = ["초전도", "rtsc", "코일", "권선", "rebco", "hts"]

[brain]
