output_dir        = exports/rna-therapy/analyze
required_deps     =
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "RNA-THERAPY analysis (open-tool compute) — TEMPLATE.",
  "open-tool (biopython) compute COPIES/derives public constants — copying/solving != demiurge measuring (g3).",
  "absorbed=true requires hexa-native re-derivation + accredited-lab data, not tool passthrough.",
]

[cell.synthesize]
substrate         = hexa
script            = stdlib/rna-therapy/synthesize.hexa
