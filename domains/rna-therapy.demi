# rna-therapy.demi — verb-cell manifest for the RNA-THERAPY (siRNA / mRNA / ASO · on-target · delivery) domain
# SSOT scripts in ~/core/hexa-lang/stdlib/rna-therapy/
# Generic dispatcher: ~/core/hexa-lang/stdlib/cockpit/cellrun.hexa
# Demiurge witness: ActionDispatch → CellrunDispatch.run("rna-therapy", verb)
#
# Format: cellrun.hexa Phase A dialect — [cell.<verb>] section headers.
#
# Citations (anchored — see domains/RNA-THERAPY.md):
#   - ViennaRNA MFE structure (open)
#   - Reynolds siRNA efficacy rules (open)
#
# Domain caveat (applies to every cell):
# rna-therapy cells run open RNA-fold + efficacy scoring — ALL cells stay GATE_OPEN / absorbed=false (g3) — real
# measurement lives in an accredited lab, not here. cellrun = D72 thin shim.

[cell.specify]
substrate         = hexa
script            = stdlib/rna-therapy/specify.hexa
record_kind       = rna-therapy_specify_record
output_dir        = exports/rna-therapy/specify
required_deps     =
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "RNA-THERAPY target spec skeleton — TEMPLATE.",
  "real specify output lives in an accredited lab / proprietary solver, not this cell.",
  "measurement_gate = GATE_OPEN permanently — specify scaffolding is not an absorption claim (g3).",
]

[cell.structure]
substrate         = hexa
script            = stdlib/rna-therapy/structure.hexa
record_kind       = rna-therapy_structure_record
output_dir        = exports/rna-therapy/structure
required_deps     =
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "RNA-THERAPY structure/geometry skeleton — TEMPLATE.",
  "real structure output lives in an accredited lab / proprietary solver, not this cell.",
  "measurement_gate = GATE_OPEN permanently — structure scaffolding is not an absorption claim (g3).",
]

