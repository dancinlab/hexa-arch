# brain.demi — verb-cell manifest for the brain (neuroscience) domain
# SSOT scripts in ~/core/hexa-lang/stdlib/brain/
# Generic dispatcher: ~/core/hexa-lang/stdlib/cockpit/cellrun.hexa
# Demiurge witness: ActionDispatch → CellrunDispatch.run("brain", verb)
#
# Format: cellrun.hexa Phase A dialect — see firmware.demi header for the
# spec. Script paths are RELATIVE to ~/core/hexa-lang/.
#
# Citations (anchored, not repeated per-cell — see domains/brain.md):
#   - Brian2 — Stimberg et al. eLife 2019 (LIF / Hodgkin-Huxley spiking)
#   - Dayan & Abbott, Theoretical Neuroscience (textbook reference)
#   - Allen Brain Atlas — measured datasets (future absorption target)
#   - Sim4Life MDDT — IEC 60601-1-2 EMC (proprietary, REGULATORY GAP)
#   - COMSOL Multiphysics — head-model EM coupling (proprietary)
#   - Anima-physics Kuramoto neuromorphic bridge — anima/anima-physics/
#     {hw,kuramoto_neuromorphic,tool}/demiurge_brain_bridge.py drops
#     records under exports/brain/verify/<UTC>Z/anima_*.json
#
# Domain caveat (applies to every cell):
# brain = adapter-only D72. Sim4Life MDDT + COMSOL absorption is REGULATORY-
# GATED proprietary territory (FDA implant clearance pathway) — this manifest
# does NOT cross that gate. Every cell defaults GATE_OPEN / absorbed=false
# (g3): textbook LIF / qualitative Kuramoto neuromorphic analog is NOT a
# measured neuron / electrophysiology / patch-clamp / Allen Brain Atlas
# absorption. The brain+verify Kuramoto bridge is intersubjective oscillator
# analog, NOT silicon spike-event hardware.

# --- UNWIRED: specify -------------------------------------------------------
[cell.specify]
substrate         = python3
python_candidates = python3.13, python3.12, python3
script            = stdlib/brain/specify.py
record_kind       = brain_specify_record
output_dir        = exports/brain/specify
required_deps     = python3
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "brain + specify scaffold pending — brain-task-requirements.json (region · cell type · stimulus protocol · readout modality) producer 미작성.",
  "domains/brain.md §1 가 SSOT 후보; Allen Brain Atlas modality vocabulary reuse.",
]

