output_dir        = exports/brain/structure
required_deps     = python3
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "brain + structure pending — connectome / morphology / cortical-area topology producer 미작성.",
  "neuromorpho.org / Allen connectivity dataset patterns; NEURON Hoc / NeuroML2 import.",
]

# --- UNWIRED: design --------------------------------------------------------
[cell.design]
substrate         = python3
