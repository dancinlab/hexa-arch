output_dir        = exports/brain/design
required_deps     = python3
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "brain + design pending — implant geometry / electrode array / stimulation waveform tradeoff producer 미작성.",
  "Sim4Life MDDT + COMSOL crossing = REGULATORY-GATED (FDA implant clearance) — design surface 은 pre-regulatory placeholder 으로만.",
]

# --- WIRED: analyze (Brian2 LIF spike-rate) ---------------------------------
[cell.analyze]
substrate         = python3
python_candidates = python3.13, python3.12, python3
script            = stdlib/brain/lif_brian2.py
record_kind       = brain_analyze_record
output_dir        = exports/brain/analyze
required_deps     = python3, brian2
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "Brian2 (Stimberg et al. eLife 2019) IS the instrument — IEEE-754 LIF integrator; 측정 숫자 (e.g. 142 Hz tonic firing · CV_ISI≈0) ARE real but the MODEL is textbook LIF (Dayan & Abbott) with constant DC drive, NOT a measured neuron.",
  "single LIF + constant drive 는 ALGORITHM verification — does Brian2's exact integrator produce the textbook firing rate? — 이지 real brain signal measurement 아님.",
  "domains/brain.md §2 proprietary gap (Sim4Life MDDT · COMSOL) untouched; Stage 4 absorbed=true requires patch-clamp data fit + multi-compartment Hodgkin-Huxley + Allen Brain Atlas absorption + bench-validated implant.",
  "measurement_gate = GATE_OPEN permanently — textbook LIF is not absorption (g3).",
  "absorbed=true 금지 — D17 g_stdlib_ownership: script SSOT 는 hexa-lang stdlib/brain/, demiurge 는 consumer-pointer 만.",
]

# --- UNWIRED: synthesize ----------------------------------------------------
[cell.synthesize]
substrate         = python3
python_candidates = python3.13, python3.12, python3
script            = stdlib/brain/synthesize.py
record_kind       = brain_synthesize_record
output_dir        = exports/brain/synthesize
required_deps     = python3
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "brain + synthesize pending — network-of-networks / cortical-column generator producer 미작성.",
  "Brian2 Network + NEURON / NetPyNE 패턴 reuse; multi-compartment HH future expansion.",
]

# --- WIRED: verify (D74 anima-physics Kuramoto neuromorphic bridge scan) ----
[cell.verify]
substrate         = python3
python_candidates = python3.13, python3.12, python3
script            = stdlib/brain/verify.py
record_kind       = brain_verify_record
output_dir        = exports/brain/verify
required_deps     = python3
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "D74 cohort scan — anima-physics Kuramoto neuromorphic bridge drops records under exports/brain/verify/<UTC>Z/anima_*.json; demiurge witnesses + aggregates, never re-measures.",
  "substrate is reference numpy Kuramoto oscillator NETWORK, NOT silicon spike-event neuromorphic hardware; the dropped records' own scope_caveats already say 'oracle parity TODO'.",
  "Sim4Life MDDT + COMSOL absorption pathway untouched (proprietary, REGULATORY-GATED — FDA implant clearance separate from this map).",
  "stdlib/brain/verify.py: cellrun honest-skip rc=2 if shim not yet present (the bridge records ARE under exports/brain/verify/ regardless — scan path is the canonical aggregator surface).",
  "measurement_gate = GATE_OPEN permanently — reference numpy network is NOT silicon-neuromorphic-hardware absorption (g3 / D17 g_stdlib_ownership).",
]

