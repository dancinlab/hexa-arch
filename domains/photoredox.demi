# photoredox.demi — verb-cell manifest for the PHOTOREDOX (photoredox catalysis · excited-state redox) domain
# SSOT scripts in ~/core/hexa-lang/stdlib/photoredox/
# Generic dispatcher: ~/core/hexa-lang/stdlib/cockpit/cellrun.hexa
# Demiurge witness: ActionDispatch → CellrunDispatch.run("photoredox", verb)
#
# Format: cellrun.hexa Phase A dialect — [cell.<verb>] section headers.
#
# Citations (anchored — see domains/PHOTOREDOX.md):
#   - Stern-Volmer quenching (open)
#   - Rehm-Weller excited-state redox (open)
#
# Domain caveat (applies to every cell):
# photoredox cells run open kinetics + descriptor estimates — ALL cells stay GATE_OPEN / absorbed=false (g3) — real
# measurement lives in an accredited lab, not here. cellrun = D72 thin shim.

[cell.specify]
substrate         = python3
python_candidates = python3.13, python3.12, python3
script            = stdlib/photoredox/specify.py
record_kind       = photoredox_specify_record
output_dir        = exports/photoredox/specify
required_deps     = python3
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "PHOTOREDOX target spec skeleton — TEMPLATE.",
  "real specify output lives in an accredited lab / proprietary solver, not this cell.",
  "measurement_gate = GATE_OPEN permanently — specify scaffolding is not an absorption claim (g3).",
]

