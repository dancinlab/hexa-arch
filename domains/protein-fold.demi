# protein-fold.demi — verb-cell manifest for the PROTEIN-FOLD (protein structure prediction · contact · pLDDT) domain
# SSOT scripts in ~/core/hexa-lang/stdlib/protein-fold/
# Generic dispatcher: ~/core/hexa-lang/stdlib/cockpit/cellrun.hexa
# Demiurge witness: ActionDispatch → CellrunDispatch.run("protein-fold", verb)
#
# Format: cellrun.hexa Phase A dialect — [cell.<verb>] section headers.
#
# Citations (anchored — see domains/PROTEIN-FOLD.md):
#   - AlphaFold pLDDT confidence (open)
#   - Ramachandran validation (open)
#
# Domain caveat (applies to every cell):
# protein-fold cells run open structure-quality metrics — ALL cells stay GATE_OPEN / absorbed=false (g3) — real
# measurement lives in an accredited lab, not here. cellrun = D72 thin shim.

[cell.specify]
substrate         = hexa
script            = stdlib/protein-fold/specify.hexa
record_kind       = protein-fold_specify_record
output_dir        = exports/protein-fold/specify
required_deps     =
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "PROTEIN-FOLD target spec skeleton — TEMPLATE.",
  "real specify output lives in an accredited lab / proprietary solver, not this cell.",
  "measurement_gate = GATE_OPEN permanently — specify scaffolding is not an absorption claim (g3).",
]

[cell.structure]
substrate         = hexa
script            = stdlib/protein-fold/structure.hexa
record_kind       = protein-fold_structure_record
output_dir        = exports/protein-fold/structure
required_deps     =
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "PROTEIN-FOLD structure/geometry skeleton — TEMPLATE.",
  "real structure output lives in an accredited lab / proprietary solver, not this cell.",
  "measurement_gate = GATE_OPEN permanently — structure scaffolding is not an absorption claim (g3).",
]

