# electrocat.demi — verb-cell manifest for the ELECTROCAT (electrocatalysis HER/OER/CO2RR · overpotential) domain
# SSOT scripts in ~/core/hexa-lang/stdlib/electrocat/
# Generic dispatcher: ~/core/hexa-lang/stdlib/cockpit/cellrun.hexa
# Demiurge witness: ActionDispatch → CellrunDispatch.run("electrocat", verb)
#
# Format: cellrun.hexa Phase A dialect — [cell.<verb>] section headers.
#
# Citations (anchored — see domains/ELECTROCAT.md):
#   - Materials Project (open) — surface energetics
#   - computational hydrogen electrode (Norskov, open)
#
# Domain caveat (applies to every cell):
# electrocat cells run CHE/scaling screens + open DFT lookup — ALL cells stay GATE_OPEN / absorbed=false (g3) — real
# measurement lives in an accredited lab, not here. cellrun = D72 thin shim.

[cell.specify]
substrate         = python3
python_candidates = python3.13, python3.12, python3
script            = stdlib/electrocat/specify.py
record_kind       = electrocat_specify_record
output_dir        = exports/electrocat/specify
required_deps     = python3
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "ELECTROCAT target spec skeleton — TEMPLATE.",
  "real specify output lives in an accredited lab / proprietary solver, not this cell.",
  "measurement_gate = GATE_OPEN permanently — specify scaffolding is not an absorption claim (g3).",
]

