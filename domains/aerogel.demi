absorbed_default  = false
scope_caveats     = [
  "AEROGEL analysis (open-tool compute) — TEMPLATE.",
  "open-tool (pymatgen) compute COPIES/derives public constants — copying/solving != demiurge measuring (g3).",
  "absorbed=true requires hexa-native re-derivation + accredited-lab data, not tool passthrough.",
]

