# aerogel.demi — verb-cell manifest for the AEROGEL (silica/graphene aerogel · porosity · thermal insulation) domain
# SSOT scripts in ~/core/hexa-lang/stdlib/aerogel/
# Generic dispatcher: ~/core/hexa-lang/stdlib/cockpit/cellrun.hexa
# Demiurge witness: ActionDispatch → CellrunDispatch.run("aerogel", verb)
#
# Format: cellrun.hexa Phase A dialect — [cell.<verb>] section headers.
#
# Citations (anchored — see domains/AEROGEL.md):
#   - pymatgen / Materials Project (open) — framework density
#   - BET surface-area + Knudsen thermal model (analytic)
#
# Domain caveat (applies to every cell):
# aerogel cells run analytic porosity/thermal screens + open DFT lookup — ALL cells stay GATE_OPEN / absorbed=false (g3) — real
# measurement lives in an accredited lab, not here. cellrun = D72 thin shim.

[cell.specify]
substrate         = hexa
script            = stdlib/aerogel/specify.hexa
record_kind       = aerogel_specify_record
output_dir        = exports/aerogel/specify
required_deps     =
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "AEROGEL target spec skeleton — TEMPLATE.",
  "real specify output lives in an accredited lab / proprietary solver, not this cell.",
  "measurement_gate = GATE_OPEN permanently — specify scaffolding is not an absorption claim (g3).",
]

[cell.structure]
substrate         = hexa
script            = stdlib/aerogel/structure.hexa
record_kind       = aerogel_structure_record
output_dir        = exports/aerogel/structure
required_deps     =
gate_default      = OPEN
absorbed_default  = false
scope_caveats     = [
  "AEROGEL structure/geometry skeleton — TEMPLATE.",
  "real structure output lives in an accredited lab / proprietary solver, not this cell.",
  "measurement_gate = GATE_OPEN permanently — structure scaffolding is not an absorption claim (g3).",
]

