// NUMB V3 — unified verify-ledger hexa-native recompute
//   Cross-checks the 5 load-bearing closed-forms that anchor G1-G7 + N1-N7
//   against the values quoted in NUMB/research/*.md.  Each block re-derives a
//   formula from first principles (no atlas lookup) and prints the recomputed
//   value next to the document value for direct PASS/FAIL inspection.
//
//   per @D g5 : hexa-native NUMERICAL recompute (🟢), NOT LLM self-judge.
//   run (local, pool-bypassed): hexa_real run NUMB/sim/v3_verify_ledger.hexa
//
//   reference_hexa_let_literal_collision: every let-literal carries a
//   block-distinct name (v3_*) so codegen cannot collapse same-named literals.
//
//   straight-line only (no arrays, no fn forward defs) — mirrors g1..g7 sims.

println("=== NUMB V3 — unified verify-ledger recompute (hexa-native) ===")
println("")

// ===========================================================================
// [V3-1] LAST body-weight scale — Cmax(ng/mL) = 0.1834 * A(cm^2)
//   doc anchors: G1 §3 / G3 §1.1 / G4 §3
//   k_lac(30m) = k_pliaglis(0.0533) * ER(3) * f_epi(0.5) * derate(0.222)
//   dose_density = m_cream(0.1475) * c_lido(0.07) * 1000
//   Cmax(A) = k_lac(30m) * dose_density * A
// ===========================================================================
let v31_k_pliaglis = 0.0533
let v31_er         = 3.0
let v31_f_epi      = 0.5
let v31_derate     = 0.222
let v31_m_cream    = 0.1475
let v31_c_lido     = 0.07
let v31_k_lac30    = v31_k_pliaglis * v31_er * v31_f_epi * v31_derate
let v31_dose_dens  = v31_m_cream * v31_c_lido * 1000.0
let v31_slope      = v31_k_lac30 * v31_dose_dens
println("[V3-1] LAST weight-scale  Cmax = slope * A")
println("  k_lac(30m)   recompute = ", v31_k_lac30, "   doc = 0.01775")
println("  dose density recompute = ", v31_dose_dens, "   doc = 10.325 mg/cm^2")
println("  slope        recompute = ", v31_slope, "   doc = 0.1834 (G1/G3/G4)")
// adolescent 400 cm^2 (G3 row) and adult 100 cm^2 (A4 anchor)
println("  Cmax(A=400)  recompute = ", v31_slope * 400.0, " ng/mL   doc(adolesc) = 73.36")
println("  Cmax(A=100)  recompute = ", v31_slope * 100.0, " ng/mL   doc(toddler+epi)=18.34")
// LAST margin vs 5000 ng/mL adult threshold
let v31_thresh = 5000.0
println("  margin(A=400) = ", v31_thresh / (v31_slope * 400.0), "x   doc = 68.16x")
println("")

// ===========================================================================
// [V3-2] onset = 2 * t_lag ; t_lag = h^2 / (6 * D)
//   doc anchors: G1 §5 / G4 §1 (h = 10um = 1e-3 cm)
//   EMLA D=1e-10 -> onset 55.56 min ; hexa-LAC v1 D=2e-9 -> onset 2.78 min
// ===========================================================================
let v32_h_cm   = 0.001                 // 10 um in cm
let v32_h2     = v32_h_cm * v32_h_cm   // cm^2
let v32_D_emla = 0.0000000001          // 1e-10 cm^2/s
let v32_D_lac  = 0.000000002           // 2e-9  cm^2/s
let v32_D_otc  = 0.0000000001          // OTC-A LMX class 1e-10
let v32_tlag_emla = v32_h2 / (6.0 * v32_D_emla)   // seconds
let v32_tlag_lac  = v32_h2 / (6.0 * v32_D_lac)
let v32_tlag_otc  = v32_h2 / (6.0 * v32_D_otc)
println("[V3-2] onset = 2*t_lag,  t_lag = h^2/(6 D)")
println("  EMLA   onset = ", 2.0 * v32_tlag_emla / 60.0, " min   doc = 55.56")
println("  LAC v1 onset = ", 2.0 * v32_tlag_lac  / 60.0, " min   doc = 2.78")
println("  OTC-A  onset = ", 2.0 * v32_tlag_otc  / 60.0, " min   doc = 55.56 (LMX class)")
println("")

// ===========================================================================
// [V3-3] Henderson-Hasselbalch free-base fraction
//   f_free = 1 / (1 + 10^(pKa - pH))
//   doc anchors: N7 §3 / G6 §5  (lid pKa 7.9 ; tet pKa 8.5)
//   10^x computed as exp(x * ln10), ln10 = 2.302585092994046
// ===========================================================================
let v33_ln10   = 2.302585092994046
let v33_lid_pka = 7.9
let v33_tet_pka = 8.5
// lid f_free at pH 5.5 / 7.4 / 8.5
let v33_d_lid_55 = v33_lid_pka - 5.5
let v33_d_lid_74 = v33_lid_pka - 7.4
let v33_d_lid_85 = v33_lid_pka - 8.5
let v33_lid_55 = 1.0 / (1.0 + exp(v33_d_lid_55 * v33_ln10))
let v33_lid_74 = 1.0 / (1.0 + exp(v33_d_lid_74 * v33_ln10))
let v33_lid_85 = 1.0 / (1.0 + exp(v33_d_lid_85 * v33_ln10))
// tet f_free at pH 5.5 / 8.5
let v33_d_tet_55 = v33_tet_pka - 5.5
let v33_d_tet_85 = v33_tet_pka - 8.5
let v33_tet_55 = 1.0 / (1.0 + exp(v33_d_tet_55 * v33_ln10))
let v33_tet_85 = 1.0 / (1.0 + exp(v33_d_tet_85 * v33_ln10))
println("[V3-3] Henderson-Hasselbalch  f_free = 1/(1+10^(pKa-pH))")
println("  lid f_free @5.5 = ", v33_lid_55, "   doc = 0.00397")
println("  lid f_free @7.4 = ", v33_lid_74, "   doc = 0.240")
println("  lid f_free @8.5 = ", v33_lid_85, "   doc = 0.799")
println("  tet f_free @5.5 = ", v33_tet_55, "   doc = 0.00100")
println("  tet f_free @8.5 = ", v33_tet_85, "   doc = 0.500")
println("")

// ===========================================================================
// [V3-4] Schroder-Van Laar binary ideal-solution liquidus
//   ln(x_i) = -(dHfus_i / R) * (1/T - 1/Tm_i)
//   doc anchor: N6 §1 / §6  (lid Tm 341.32 K, tet Tm 316.08 K, dHfus 17 kJ/mol)
//   anchor truth = Yuan 2015 measured lid+tet 1:1 eutectic = 29.95 C (303.10 K)
//   At T = 303.15 K (30 C) the SVL sum-of-mole-fractions trend (doc = 1.2173).
// ===========================================================================
let v34_R       = 8.314          // J/(mol K)
let v34_dH      = 17000.0        // J/mol (lid & tet estimate)
let v34_Tm_lid  = 341.32         // K
let v34_Tm_tet  = 316.08         // K
let v34_T       = 303.15         // K (30 C)
// x_i = exp( -(dH/R) * (1/T - 1/Tm_i) )
let v34_arg_lid = (0.0 - (v34_dH / v34_R)) * ((1.0 / v34_T) - (1.0 / v34_Tm_lid))
let v34_arg_tet = (0.0 - (v34_dH / v34_R)) * ((1.0 / v34_T) - (1.0 / v34_Tm_tet))
let v34_x_lid   = exp(v34_arg_lid)
let v34_x_tet   = exp(v34_arg_tet)
println("[V3-4] Schroder-Van Laar  x_i = exp(-(dH/R)(1/T - 1/Tm_i))")
println("  x_lid @30C = ", v34_x_lid, "   (SVL ideal; doc Taylor-4 = 0.4587)")
println("  x_tet @30C = ", v34_x_tet, "   (SVL ideal; doc Taylor-4 = 0.7586)")
println("  sum x_i    = ", v34_x_lid + v34_x_tet, "   doc(Taylor-4) = 1.2173")
println("  NOTE: Yuan 2015 MEASURED eutectic = 29.95C anchors truth; libm exp")
println("        gives exact SVL ideal-soln value (doc sim used Taylor-4 approx).")
println("")

// ===========================================================================
// [V3-5] Arrhenius shelf-life — epi oxidation gate + lid hydrolysis t90
//   AF(40/25) = exp( (Ea/R) * (1/T25 - 1/T40) )
//   doc anchor: G5 §2  (R = 1.987e-3 kcal/mol/K)
//   epi Ea = 18 kcal/mol -> AF 4.29 ; lid Ea = 33.8 -> AF 15.39
//   epi shelf @25C = 6 mo accel(40C) * AF = 25.7 mo
//   lid t90 @25C from k(80C)=1.37e-9/s, Ea=33.8 -> ~17,700 yr
// ===========================================================================
let v35_Rk    = 0.001987     // kcal/mol/K
let v35_T25   = 298.15
let v35_T40   = 313.15
let v35_T80   = 353.15
let v35_inv_dT = (1.0 / v35_T25) - (1.0 / v35_T40)
// epi AF
let v35_Ea_epi = 18.0
let v35_af_epi = exp((v35_Ea_epi / v35_Rk) * v35_inv_dT)
// lid AF
let v35_Ea_lid = 33.8
let v35_af_lid = exp((v35_Ea_lid / v35_Rk) * v35_inv_dT)
println("[V3-5] Arrhenius  AF(40/25) = exp((Ea/R)(1/T25 - 1/T40))")
println("  1/T25 - 1/T40 = ", v35_inv_dT, "   doc = 0.000160659")
println("  epi AF (Ea=18.0) = ", v35_af_epi, "   doc = 4.289")
println("  lid AF (Ea=33.8) = ", v35_af_lid, "   doc = 15.39")
// epi shelf-life: 6 mo at 40C extrapolated to 25C
let v35_epi_shelf = 6.0 * v35_af_epi
println("  epi shelf @25C = ", v35_epi_shelf, " mo   doc = 25.73 (gate; +1.7mo over 24)")
// lid t90: k(80C) -> k(25C) via Arrhenius, t90 = -ln(0.9)/k
let v35_k80    = 0.00000000137                 // 1.37e-9 /s (Powell 1987, 80C)
let v35_arg80  = (v35_Ea_lid / v35_Rk) * ((1.0 / v35_T25) - (1.0 / v35_T80))
let v35_k25    = v35_k80 * exp(0.0 - v35_arg80)
let v35_neglog = 0.10536051565782628           // -ln(0.9)
let v35_t90_s  = v35_neglog / v35_k25          // seconds
let v35_t90_yr = v35_t90_s / 31557600.0        // yr (365.25 d)
println("  lid hydrolysis arg(80->25) = ", v35_arg80, "   doc = 8.886")
println("  lid k(25C) = ", v35_k25, " /s   doc = 1.885e-13")
println("  lid t90 @25C = ", v35_t90_yr, " yr   doc = 17,723 (NOT shelf-limiting)")
println("")

println("=== V3 recompute COMPLETE — all 5 closed-forms cross-checked vs doc ===")
println("=== [V3-1] slope 0.1834 [V3-2] onset 2.78/55.6 [V3-3] HH f_free ===")
println("=== [V3-4] SVL trend (Yuan 29.95C anchor) [V3-5] epi 25.7mo / lid 17.7k yr ===")
