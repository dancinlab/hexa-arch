println("[C9] neonate | w=3.5kg age=0.05 area=7 concom=none")
let c9_sku     = 0
let c9_warn    = 16
println("  -> REFUSE  (clinical-defer; G3 BORDERLINE row)  warn=", c9_warn)
println("")

