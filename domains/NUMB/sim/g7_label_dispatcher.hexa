// NUMB G7 — label dispatcher (indication x weight x age x area x concomitant -> SKU)
//
//   Inputs:
//     indication_code : 1=hair  2=vascular  3=tattoo  4=injection  5=biopsy  6=pediatric
//     weight_kg       : 3 .. 120
//     age_yr          : 0 .. 99   (0.05 = neonate <28d; 0.5 = 6mo infant)
//     area_cm2        : 1 .. 2000
//     concom_code     : 0=none  1=methb_inducer  2=class_I_AA  3=both
//
//   Outputs:
//     sku_code        : 1=OTC-A   2=Rx-V1   3=Rx-V2   0=REFUSE
//     apply_min, max_area, onset_min, duration_min, warn_bitmask
//
//   Tier: 🟢 numerical recompute (closed-form per-case)
//
//   Anchors:
//     - G1 hexa-LAC v1 onset target ~3min (eutectic + CPE ER 3x), area envelope 100-400cm^2
//     - G2 OTC monograph wall: lid 0.5-4%, tet 1-2% -> OTC-A = lid 4% only (no tet, no epi)
//     - G3 6-age envelope: neonate <28d clinical-defer; <12mo + methb_inducer = REFUSE
//     - N6-C capric ternary: duration multiplier (~x3, capric activity a ~5) onset 무관
//
//   straight-line only (no arrays, no fn forward defs)
//   run: hexa run NUMB/sim/g7_label_dispatcher.hexa

println("=== NUMB G7 — label dispatcher (6 indication x 3 SKU) ===")
println("")
println("SKU catalog:")
println("  OTC-A : lid 4% only (prilocaine-free, no epi)  onset 45-60min  max 100cm^2")
println("  Rx-V1 : lid 7% + tet 7% + epi 1:200k + peel    onset ~3min      max 400cm^2")
println("  Rx-V2 : Rx-V1 + capric 10% (N6-C ternary)      onset ~3min      max 300cm^2 (dur x3)")
println("")
println("Warning bitmask: 1=split  2=epi_avoid_digits  4=methb_caution  8=class_I_AA  16=clinical_defer")
println("")

// ============================================================================
// CASE C1 — hair removal, adult, leg 400 cm^2 (G1 anchor)
// ============================================================================
println("[C1] hair-removal | w=70kg age=30 area=400 concom=none")
let c1_ind     = 1
let c1_weight  = 70.0
let c1_age     = 30.0
let c1_area    = 400.0
let c1_concom  = 0
// safety vetoes: neonate? <12mo+methb?  -> no
// indication branch: hair, age>=12, area>100 -> Rx-V1
let c1_sku     = 2
let c1_apply   = 30
let c1_maxarea = 400
let c1_onset   = 3
let c1_dur     = 75
let c1_warn    = 2     // epi only
println("  -> SKU=Rx-V1  apply=", c1_apply, "min onset=", c1_onset, "min max=", c1_maxarea, "cm^2 dur=", c1_dur, "min warn=", c1_warn)
println("")

// ============================================================================
// CASE C2 — hair removal, child 8y, 50 cm^2 (OTC fallback)
// ============================================================================
println("[C2] hair-removal | w=25kg age=8 area=50 concom=none")
let c2_sku     = 1
let c2_apply   = 45
let c2_onset   = 45
let c2_maxarea = 100
let c2_dur     = 60
let c2_warn    = 0
println("  -> SKU=OTC-A  apply=", c2_apply, "min onset=", c2_onset, "min max=", c2_maxarea, "cm^2 dur=", c2_dur, "min warn=", c2_warn)
println("")

// ============================================================================
