\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces The tabletop laser-plasma accelerator chain. \textbf  {This stack closes the five physics stages} \textcircled {\scriptsize  2}\textcircled {\scriptsize  3}\textcircled {\scriptsize  4}\textcircled {\scriptsize  5}\textcircled {\scriptsize  6} (\textcolor {green!60!black}{\rule  [0.05ex]{1.0ex}{1.0ex}}/\textcolor {blue!70!black}{\rule  [0.05ex]{1.0ex}{1.0ex}}) to a numerical or closed-form verdict. The drive stage \textcircled {\scriptsize  1} (\textcolor {orange!90!black}{\rule  [0.05ex]{1.0ex}{1.0ex}}) is upstream driver hardware (wet-lab), and the event-analysis stage \textcircled {\scriptsize  7} (\textcolor {orange!90!black}{\rule  [0.05ex]{1.0ex}{1.0ex}}) is a synthetic-LHE round-trip held permanently at \texttt  {absorbed=false} --- it is a parser single-point, not tuned Monte Carlo with detector simulation. The table is the contract: \textcolor {orange!90!black}{\rule  [0.05ex]{1.0ex}{1.0ex}}\ does not graduate to \textcolor {green!60!black}{\rule  [0.05ex]{1.0ex}{1.0ex}}\ without an external measurement, a tuned generator, or a sourced detector model. Two downstream items --- the Geant4-MC Stage~4 stopping correction and the GPU-heavy 2-D nonlinear blowout PIC --- are deliberately \emph  {not in this table} because they are out of the demiurge clean-room scope (\S  \ref {sec:limits}).}}{4}{table.caption.6}\protected@file@percent }
\newlabel{tab:pipeline}{{1}{4}{The tabletop laser-plasma accelerator chain. \textbf {This stack closes the five physics stages} \textcircled {\scriptsize 2}\textcircled {\scriptsize 3}\textcircled {\scriptsize 4}\textcircled {\scriptsize 5}\textcircled {\scriptsize 6} (\tierGreen /\tierBlue ) to a numerical or closed-form verdict. The drive stage \textcircled {\scriptsize 1} (\tierOrange ) is upstream driver hardware (wet-lab), and the event-analysis stage \textcircled {\scriptsize 7} (\tierOrange ) is a synthetic-LHE round-trip held permanently at \texttt {absorbed=false} --- it is a parser single-point, not tuned Monte Carlo with detector simulation. The table is the contract: \tierOrange \ does not graduate to \tierGreen \ without an external measurement, a tuned generator, or a sourced detector model. Two downstream items --- the Geant4-MC Stage~4 stopping correction and the GPU-heavy 2-D nonlinear blowout PIC --- are deliberately \emph {not in this table} because they are out of the demiurge clean-room scope (\S \ref {sec:limits})}{table.caption.6}{}}
