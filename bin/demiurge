#!/usr/bin/env bash
# demiurge — hx package entry point (hx convention: <pkg>/bin/<name>).
# Installed via `hx install /Users/ghost/core/demiurge`, then reachable
# as `demiurge <subcommand>` through the hx shim.
#
#   demiurge install        build + install /Applications/demiurge.app
#   demiurge run            launch the installed app
#   demiurge cli <args...>  run DemiurgeCLI (list-records / show / …)
#   demiurge                this help
set -euo pipefail

# Resolve through the hx shim symlink chain (~/.hx/bin/demiurge →
# ~/.hx/packages/demiurge/bin/demiurge, and the packages/demiurge dir
# is itself a symlink to the real repo) so REPO is the actual checkout.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
REPO="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"

case "${1:-}" in
  install)
    exec bash "$REPO/cockpit/install.sh"
    ;;
  run)
    if [ -d /Applications/demiurge.app ]; then
      exec open /Applications/demiurge.app
    else
      echo "demiurge: not installed — run 'demiurge install' first" >&2
      exit 1
    fi
    ;;
  cli)
    shift
    cd "$REPO/cockpit"
    exec swift run DemiurgeCLI "$@"
    ;;
  ""|-h|--help|help)
    cat <<'USAGE'
demiurge — universal hexa-native technical-design architecture program

  demiurge install        build + install /Applications/demiurge.app
  demiurge run            launch the installed cockpit app
  demiurge cli <args...>  run DemiurgeCLI (list-records / list-decisions
                          / list-rfcs / list-domains / show <path> / …)
  demiurge --help         this help

The macOS cockpit GUI is the user surface; the CLI is the AI-agent
surface (design.md D34). See cockpit/README.md.
USAGE
    ;;
  *)
    echo "demiurge: unknown subcommand '$1' — try 'demiurge --help'" >&2
    exit 2
    ;;
esac
