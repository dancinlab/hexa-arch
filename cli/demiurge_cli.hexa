// cli/demiurge_cli.hexa — demiurge 의 hexa-native CLI 진입점 (g1).
//
// 스위프트 `cockpit/Sources/DemiurgeCLI/main.swift` 를 대체하는 hexa-native
// 코어. `demiurge cli <verb>` 사용자 표면을 그대로 보존하며, `bin/demiurge`
// 가 (parity 도달 후) 이 바이너리로 라우팅한다. 그 전까지 스위프트가 라이브.
//
// 정규 패턴 (tool/*_cli.hexa → bin/hexa-* 와 동일):
//   - args() 로 argv 를 읽고, _slice_args() 가 verb 부터의 슬라이스를 만든다
//     (직접 실행 `demiurge_cli <verb>` · `hexa run cli/demiurge_cli.hexa <verb>`
//      두 경우 모두 처리 — env.hexa 의 .hexa-경로 토큰 감지 관용구를 따른다).
//   - VERB 레지스트리(데이터 테이블)가 SSOT — 추가/이름변경/삭제는 manifest-only.
//     generic 층은 verb 이름으로 분기하지 않고, 레지스트리를 순회해 검증한
//     뒤 단일 dispatch 지점으로 넘긴다 (@D d4 — 단일 generic dispatch).
//
// 이식 상태: PR1 = 스캐폴드 + generic dispatcher + `version` verb 만.
//   discover/synth/action/analyze/llm/atlas/… 는 후속 스택 PR 에서 verb-그룹별.
//   parity 도달 전까지 bin/demiurge 는 스위프트 CLI 로 라우팅 (절반-전환 금지).

// 스위프트 코어와 동일한 버전 단일출처 (#516 — 래퍼/코어 표면 일치 보존).
let DEMIURGE_CLI_VERSION = "0.0.2 (phase α-3 + β, read-only — rfc_011 §10)"

// ── VERB 레지스트리 (데이터 테이블 · d4 SSOT) ──────────────────────────────
//
// 각 행 = { name, summary }. generic 층은 이 테이블만 보고 검증/usage 를
// 렌더한다. 새 verb 이식 = 이 테이블에 한 줄 추가 + dispatch 한 줄
// (per-verb 하드코딩을 generic 층에 두지 않는다).
struct VerbSpec {
  name:    string,
  summary: string,
  ported:  bool      // true = hexa-native 구현 완료, false = 아직 스위프트
}

fn _verb_registry() -> [VerbSpec] {
  return [
    VerbSpec { name: "version",         summary: "버전 배너 출력",                         ported: true },
    // ── DemiurgeCore-port read-only list-* (PR-A) ──
    VerbSpec { name: "list-all",        summary: "모든 종류 아티팩트 나열",                ported: true },
    VerbSpec { name: "list-records",    summary: "exports/ F1F2 레코드 나열",              ported: true },
    VerbSpec { name: "list-decisions",  summary: "design.md 결정 나열",                    ported: true },
    VerbSpec { name: "list-rfcs",       summary: "proposals/rfc_*.md 나열",                ported: true },
    VerbSpec { name: "list-domains",    summary: "domains/*.md 나열",                      ported: true },
    // ── 후속 스택 PR 에서 ported:true 로 전환 ──
    VerbSpec { name: "show",            summary: "F1F2 레코드 1건 + provenance",           ported: true },
    VerbSpec { name: "list-projects",   summary: "워크벤치 프로젝트 나열",                 ported: true },
    VerbSpec { name: "show-project",    summary: "프로젝트 1건 + 7-verb 진행도",           ported: true },
    VerbSpec { name: "project",         summary: "프로젝트 new|advance|retreat",           ported: false },
    VerbSpec { name: "list-shelf",      summary: "도메인 §6 ingredient shelf",             ported: false },
    VerbSpec { name: "action",          summary: "θ-2 액션 dispatch (verb · domain)",      ported: false },
    VerbSpec { name: "discover",        summary: "8-verb head — phanes-bridged 발견",      ported: true },
    VerbSpec { name: "list-gates",      summary: "gate 별 F1F2 레코드",                    ported: true },
    VerbSpec { name: "gate-summary",    summary: "gate + absorbed 합계",                   ported: true },
    VerbSpec { name: "operate",         summary: "operation manifest list|audit",          ported: true },
    VerbSpec { name: "backend",         summary: "compute backend list|current",           ported: true },
    VerbSpec { name: "compose",         summary: "도메인 → 구성 스택 해소",                ported: false },
    VerbSpec { name: "verify",          summary: "provenance/claim-gate · hexa verify",    ported: true },
    VerbSpec { name: "atlas",           summary: "hexa atlas SSOT 읽기/owner-write",       ported: true },
    VerbSpec { name: "owner",           summary: "owner-mode (사장실) 상태",               ported: true },
    VerbSpec { name: "llm",             summary: "AI 연결 (Claude/Codex/Gemini)",          ported: false },
    VerbSpec { name: "emit-component",  summary: "BIPV 컴포넌트 아티팩트 emit",            ported: false },
    VerbSpec { name: "export-component",summary: "번들 geometry export (usda|stl)",        ported: false }
  ]
}

// ── argv 슬라이싱 — verb 부터의 슬라이스 (직접 실행 + hexa run 양쪽) ──────────
fn _slice_args() -> array {
  let av = args()
  let n = len(av)
  let mut i = 1
  while i < n {
    let a = to_string(av[i])
    // `hexa run cli/demiurge_cli.hexa <verb> ...` 경우: 스크립트 경로 토큰
    // 다음부터가 사용자 인자.
    if a.ends_with("/demiurge_cli.hexa") || a.ends_with("demiurge_cli.hexa") {
      let mut out = []
      let mut j = i + 1
      while j < n { out.push(to_string(av[j])); j = j + 1 }
      return out
    }
    i = i + 1
  }
  // 직접 실행 (`demiurge_cli <verb> ...`): argv[0]=binary, argv[1..]=사용자 인자.
  let mut out = []
  let mut j = 1
  while j < n { out.push(to_string(av[j])); j = j + 1 }
  return out
}

// ── usage — VERB 레지스트리(데이터)에서 직접 렌더 ────────────────────────────
fn _usage() {
  println("demiurge — Demiurge hexa-native CLI")
  println("")
  println("USAGE: demiurge cli <verb> [args]")
  println("")
  let reg = _verb_registry()
  let mut i = 0
  while i < len(reg) {
    let v = reg[i]
    let mark = if v.ported { "  " } else { "· " }   // ·  = 스위프트 폴백 (미이식)
    let pad_n = 18 - len(v.name)
    let mut pad = ""
    let mut k = 0
    while k < pad_n { pad = pad + " "; k = k + 1 }
    println("  " + mark + v.name + pad + v.summary)
    i = i + 1
  }
  println("")
  println("  ·  = 아직 스위프트 폴백 (hexa-native 이식 진행 중)")
}

// ── 공용 헬퍼 ────────────────────────────────────────────────────────────────
//
// shell single-quote escape: ' → '\''  (exec() 임베딩 안전).
fn _shq(s: string) -> string {
  let mut out = "'"
  let n = len(s)
  let mut i = 0
  while i < n {
    let c = s.substring(i, i + 1)
    if c == "'" { out = out + "'\\''" } else { out = out + c }
    i = i + 1
  }
  return out + "'"
}

fn _file_exists(p: string) -> bool {
  return to_string(exec("test -x " + _shq(p) + " && echo Y || echo N")).trim() == "Y"
}

fn _path_exists(p: string) -> bool {
  return to_string(exec("test -e " + _shq(p) + " && echo Y || echo N")).trim() == "Y"
}

// ════════════════════════════════════════════════════════════════════════════
// DemiurgeCore-port — 스위프트 `cockpit/Sources/DemiurgeCore/` 의 read-only
// 파트(ArtifactRegistry · ArtifactStub · F1F2Record · RecordLoader)를 hexa-
// native 로 이식. import 없는 단일 파일 빌드(알려진 빌드-우회)를 유지하기 위해
// 스캐폴드 패턴 그대로 인라인하되, 이 배너로 명확히 구획한다. (별도 cli/core/*
// 파일은 flatten/build 단계의 import 해소가 필요 → 빌드-우회 범위 밖.)
// ════════════════════════════════════════════════════════════════════════════

// ── RecordLoader.exportsRoot 와 동일 해소 (스위프트 RecordLoader.swift §48) ──
//   1. $DEMIURGE_REPO/exports (env 설정 시 · 설치된 앱 경로)
//   2. else <cwd>/../exports (`swift run` cwd=cockpit/ 케이스와 byte-identical)
fn _exports_root() -> string {
  let repo = env("DEMIURGE_REPO")
  if repo.len() > 0 { return repo + "/exports" }
  let cwd = to_string(exec("pwd")).trim()
  return cwd + "/../exports"
}

// f1f2RecordsRoot — exportsRoot/chip/noc/f1f2/records (스위프트 §60).
fn _f1f2_root() -> string {
  return _exports_root() + "/chip/noc/f1f2/records"
}

// projectRoot — exportsRoot 의 부모 (ArtifactRegistry.swift §180).
fn _project_root() -> string {
  return _exports_root() + "/.."
}

// ArtifactStub — { id_display, title, path } (ArtifactStub.swift §44).
// id_display = "$R<n>" / "$D<n>" / "$RFC<n>" / "$DOM:<name>".
struct ArtifactStub {
  id_display: string,
  title:      string,
  path:       string
}

// ArtifactKind prefix (ArtifactStub.swift §23).
fn _kind_prefix(kind: string) -> string {
  if kind == "f1f2"     { return "$R" }
  if kind == "decision" { return "$D" }
  if kind == "rfc"      { return "$RFC" }
  if kind == "domain"   { return "$DOM:" }
  return "$"
}

// ArtifactKind rawValue — 헤더 라벨 (ArtifactStub.swift §16).
fn _kind_label(kind: string) -> string {
  if kind == "f1f2"     { return "Records" }
  if kind == "decision" { return "Decisions" }
  if kind == "rfc"      { return "RFCs" }
  if kind == "domain"   { return "Domains" }
  return kind
}

// ── ArtifactRegistry.loadF1F2 (ArtifactRegistry.swift §39) ──────────────────
// exports/chip/noc/f1f2/records/*.json — 파일명 정렬 후 1-based index id.
fn _load_f1f2() -> [ArtifactStub] {
  let mut out = []
  let root = _f1f2_root()
  if !_path_exists(root) { return out }
  // 파일명만, .json 만, 정렬 (스위프트 sorted{lastPathComponent}).
  let listing = to_string(exec(
    "ls -1 " + _shq(root) + " 2>/dev/null | grep '\\.json$' | LC_ALL=C sort"))
  let lines = listing.split("\n")
  let mut i = 0
  let mut n = 0
  while i < len(lines) {
    let fname = to_string(lines[i]).trim()
    i = i + 1
    if fname.len() == 0 { continue }
    n = n + 1
    // title = deletingPathExtension (".json" 제거).
    let stem = fname.substring(0, fname.len() - 5)
    out.push(ArtifactStub {
      id_display: "$R" + to_string(n),
      title:      stem,
      path:       root + "/" + fname
    })
  }
  return out
}

// ── ArtifactRegistry.loadDecisions (ArtifactRegistry.swift §63) ─────────────
// design.md 에서 `### Decision N — <title>` 파싱, N 중복 제거(첫째 유지),
// N 숫자 정렬. id="$D<n>", title="D<n> — <title>".
fn _load_decisions() -> [ArtifactStub] {
  let mut out = []
  let path = _project_root() + "/design.md"
  if !_path_exists(path) { return out }
  // 헤딩 라인만 추출 (앵커 ^### Decision).
  let raw = to_string(exec(
    "grep -E '^### Decision [0-9]+ — ' " + _shq(path) + " 2>/dev/null"))
  let lines = raw.split("\n")
  let mut seen = ""
  let mut i = 0
  while i < len(lines) {
    let line = to_string(lines[i]).trim()
    i = i + 1
    if line.len() == 0 { continue }
    // "### Decision " 접두 제거 후 N 과 title 분리.
    let rest = line.substring(13, line.len())   // len("### Decision ")=13
    // N = 선행 숫자.
    let mut j = 0
    while j < rest.len() {
      let c = rest.substring(j, j + 1)
      if c < "0" || c > "9" { break }
      j = j + 1
    }
    if j == 0 { continue }
    let num = rest.substring(0, j)
    // 중복 N 제거 (첫째 유지).
    let mark = "|" + num + "|"
    if seen.contains(mark) { continue }
    seen = seen + mark
    // title = " — " 다음 부분.
    let after = rest.substring(j, rest.len())
    let mut title = after
    let dash = after.index_of(" — ")
    if dash >= 0 { title = after.substring(dash + 3, after.len()) }
    out.push(ArtifactStub {
      id_display: "$D" + num,
      title:      "D" + num + " — " + title,
      path:       path
    })
  }
  // N 숫자 정렬 (insertion sort — grep 순서는 이미 파일순이나 안전하게).
  let mut a = 0
  while a < len(out) {
    let mut b = a + 1
    while b < len(out) {
      if _stub_dnum(out[b]) < _stub_dnum(out[a]) {
        let tmp = out[a]; out[a] = out[b]; out[b] = tmp
      }
      b = b + 1
    }
    a = a + 1
  }
  return out
}

// "$D<n>" → n (정렬 키).
fn _stub_dnum(s: ArtifactStub) -> int {
  let d = s.id_display.substring(2, s.id_display.len())   // "$D" 제거
  return to_int(d)
}

// ── ArtifactRegistry.loadRFCs (ArtifactRegistry.swift §95) ──────────────────
// proposals/rfc_*.md — 파일명 정렬, stem 의 두번째 "_" 토큰 = N.
fn _load_rfcs() -> [ArtifactStub] {
  let mut out = []
  let dir = _project_root() + "/proposals"
  if !_path_exists(dir) { return out }
  let listing = to_string(exec(
    "ls -1 " + _shq(dir) + " 2>/dev/null | grep -E '^rfc_.*\\.md$' | LC_ALL=C sort"))
  let lines = listing.split("\n")
  let mut i = 0
  while i < len(lines) {
    let fname = to_string(lines[i]).trim()
    i = i + 1
    if fname.len() == 0 { continue }
    let stem = fname.substring(0, fname.len() - 3)   // ".md" 제거
    // parts = stem.split("_"), N = parts[1].
    let parts = stem.split("_")
    if len(parts) < 2 { continue }
    let num = to_string(parts[1])
    out.push(ArtifactStub {
      id_display: "$RFC" + num,
      title:      stem,
      path:       dir + "/" + fname
    })
  }
  return out
}

// ── ArtifactRegistry.loadDomains (ArtifactRegistry.swift §122) ──────────────
// domains/*.md (README.md 제외) — id="$DOM:<name>", 최종 id.key 정렬.
// domains/matter/README.md 가 있으면 matter 포인터 추가.
fn _load_domains() -> [ArtifactStub] {
  let mut out = []
  let dir = _project_root() + "/domains"
  if !_path_exists(dir) { return out }
  let listing = to_string(exec(
    "ls -1 " + _shq(dir) + " 2>/dev/null | grep -E '\\.md$' | LC_ALL=C sort"))
  let lines = listing.split("\n")
  let mut i = 0
  while i < len(lines) {
    let fname = to_string(lines[i]).trim()
    i = i + 1
    if fname.len() == 0 { continue }
    if fname == "README.md" { continue }
    let name = fname.substring(0, fname.len() - 3)
    out.push(ArtifactStub {
      id_display: "$DOM:" + name,
      title:      name,
      path:       dir + "/" + fname
    })
  }
  // matter 포인터 (스위프트 §141).
  let matter = dir + "/matter/README.md"
  if _path_exists(matter) {
    out.push(ArtifactStub {
      id_display: "$DOM:matter",
      title:      "matter (pointer — D17 hexa-lang absorbed)",
      path:       matter
    })
  }
  // 최종 id.key 정렬 (스위프트 §149: sorted{id.key}).
  let mut a = 0
  while a < len(out) {
    let mut b = a + 1
    while b < len(out) {
      if _dom_key(out[b]) < _dom_key(out[a]) {
        let tmp = out[a]; out[a] = out[b]; out[b] = tmp
      }
      b = b + 1
    }
    a = a + 1
  }
  return out
}

// "$DOM:<name>" → name (정렬 키).
fn _dom_key(s: ArtifactStub) -> string {
  return s.id_display.substring(5, s.id_display.len())   // "$DOM:" 제거
}

// ArtifactRegistry.load(kind:) dispatch (ArtifactRegistry.swift §28).
fn _registry_load(kind: string) -> [ArtifactStub] {
  if kind == "f1f2"     { return _load_f1f2() }
  if kind == "decision" { return _load_decisions() }
  if kind == "rfc"      { return _load_rfcs() }
  if kind == "domain"   { return _load_domains() }
  return []
}

// ── DemiurgeCLI.list(kind:) 렌더 (main.swift §145) ──────────────────────────
//   <rawValue> (<count>):
//     <id.display><pad>  <title>
// pad = 이 batch 의 최장 id.display 에 정렬.
fn _list_kind(kind: string) -> int {
  let stubs = _registry_load(kind)
  println(_kind_label(kind) + " (" + to_string(len(stubs)) + "):")
  let mut max_len = 0
  let mut i = 0
  while i < len(stubs) {
    let l = stubs[i].id_display.len()
    if l > max_len { max_len = l }
    i = i + 1
  }
  i = 0
  while i < len(stubs) {
    let s = stubs[i]
    let mut pad = ""
    let mut k = s.id_display.len()
    while k < max_len { pad = pad + " "; k = k + 1 }
    println("  " + s.id_display + pad + "  " + s.title)
    i = i + 1
  }
  return 0
}

// ── DemiurgeCLI.listAll (main.swift §158) — allCases 순서 + 각 뒤 빈 줄 ──────
fn _cmd_list_all() -> int {
  _list_kind("f1f2");     println("")
  _list_kind("decision"); println("")
  _list_kind("rfc");      println("")
  _list_kind("domain");   println("")
  return 0
}

// ════════════════════════════════════════════════════════════════════════════
// RecordLoader (load+show) + F1F2Record reader — 스위프트 RecordLoader.swift +
// F1F2Record.swift + main.swift show() 이식 (PR-B). path-jail 보존:
// exports/** 밖 경로는 invariant-a 로 거부 (스위프트와 byte-identical wording).
// ════════════════════════════════════════════════════════════════════════════

// 경로를 cwd 기준 절대경로로 lexical 정규화 (스위프트 standardizedFileURL —
// `..`/`.` 만 해소, 심볼릭링크는 해소하지 않음). python os.path.normpath 가
// 동일 의미 (lexical) → exec 로 위임해 byte-identical 절대경로 산출.
fn _canonical_path(rel: string) -> string {
  let cmd = "python3 -c 'import os,sys; print(os.path.normpath(os.path.join(os.getcwd(), sys.argv[1])))' " + _shq(rel)
  return to_string(exec(cmd)).trim()
}

// JSON 문자열에서 키 위치 다음의 raw 토큰(따옴표 안 또는 다음 구분자까지)을
// 추출. depth-안전을 위해 "key" 의 첫 출현 + 콜론 다음을 읽는다 (F1F2 스키마는
// 각 객체 안에서 키가 유일 → 단순 first-match 로 충분, 스위프트 Codable 과 동일
// 값에 도달). 객체 스코프 제한은 _json_str_in 으로 처리.
// 객체 블록 안에서 키는 유일하므로 from 인자는 항상 0 (index_of 전체 검색).
fn _find_colon_after_key(src: string, key: string, from: int) -> int {
  let needle = "\"" + key + "\""
  let kpos = src.index_of(needle)
  if kpos < 0 { return -1 }
  let mut i = kpos + needle.len()
  // 콜론까지 공백 스킵.
  while i < src.len() {
    let c = src.substring(i, i + 1)
    if c == ":" { return i + 1 }
    if c == " " || c == "\t" || c == "\n" || c == "\r" { i = i + 1; continue }
    return -1
  }
  return -1
}

// "key": "string-value"  → string-value (이스케이프 \" \\ \n 디코드).
fn _json_string(src: string, key: string, from: int) -> string {
  let cp = _find_colon_after_key(src, key, from)
  if cp < 0 { return "" }
  let mut i = cp
  while i < src.len() {
    let c = src.substring(i, i + 1)
    if c == " " || c == "\t" || c == "\n" || c == "\r" { i = i + 1; continue }
    break
  }
  if i >= src.len() || src.substring(i, i + 1) != "\"" { return "" }
  i = i + 1
  let mut out = ""
  while i < src.len() {
    let c = src.substring(i, i + 1)
    if c == "\\" {
      let nx = src.substring(i + 1, i + 2)
      if nx == "n" { out = out + "\n" }
      else if nx == "t" { out = out + "\t" }
      else if nx == "\"" { out = out + "\"" }
      else if nx == "\\" { out = out + "\\" }
      else if nx == "/" { out = out + "/" }
      else { out = out + nx }
      i = i + 2
      continue
    }
    if c == "\"" { break }
    out = out + c
    i = i + 1
  }
  return out
}

// "key": <number-or-bool-or-bareword>  → 토큰 문자열 (콤마/중괄호 전까지 trim).
fn _json_scalar(src: string, key: string, from: int) -> string {
  let cp = _find_colon_after_key(src, key, from)
  if cp < 0 { return "" }
  let mut i = cp
  while i < src.len() {
    let c = src.substring(i, i + 1)
    if c == " " || c == "\t" || c == "\n" || c == "\r" { i = i + 1; continue }
    break
  }
  let mut out = ""
  while i < src.len() {
    let c = src.substring(i, i + 1)
    if c == "," || c == "}" || c == "]" || c == "\n" { break }
    out = out + c
    i = i + 1
  }
  return out.trim()
}

// "key": "value" 가 src 안에 존재하는지 (필수필드 누락 → decode 실패 판정용).
fn _json_has_key(src: string, key: string) -> bool {
  return src.contains("\"" + key + "\"")
}

// 객체 블록 추출: "key": { ... } 의 균형 잡힌 중괄호 내부. (topology/verdict/
// provenance 같은 중첩 객체를 그 스코프 안에서만 키 탐색하기 위함.)
fn _json_object_block(src: string, key: string) -> string {
  let cp = _find_colon_after_key(src, key, 0)
  if cp < 0 { return "" }
  let mut i = cp
  while i < src.len() && src.substring(i, i + 1) != "{" { i = i + 1 }
  if i >= src.len() { return "" }
  let start = i
  let mut depth = 0
  while i < src.len() {
    let c = src.substring(i, i + 1)
    if c == "{" { depth = depth + 1 }
    else if c == "}" { depth = depth - 1; if depth == 0 { return src.substring(start, i + 1) } }
    i = i + 1
  }
  return ""
}

// "key": [ "a", "b", ... ]  → 문자열 원소 배열 (스위프트 [String] 디코드).
fn _json_string_array(src: string, key: string) -> array {
  let mut out = []
  let cp = _find_colon_after_key(src, key, 0)
  if cp < 0 { return out }
  let mut i = cp
  while i < src.len() && src.substring(i, i + 1) != "[" { i = i + 1 }
  if i >= src.len() { return out }
  i = i + 1
  // [ ... ] 내부에서 따옴표 문자열을 순차 추출.
  while i < src.len() {
    let c = src.substring(i, i + 1)
    if c == "]" { break }
    if c == "\"" {
      i = i + 1
      let mut s = ""
      while i < src.len() {
        let cc = src.substring(i, i + 1)
        if cc == "\\" {
          let nx = src.substring(i + 1, i + 2)
          if nx == "n" { s = s + "\n" }
          else if nx == "t" { s = s + "\t" }
          else if nx == "\"" { s = s + "\"" }
          else if nx == "\\" { s = s + "\\" }
          else if nx == "/" { s = s + "/" }
          else { s = s + nx }
          i = i + 2
          continue
        }
        if cc == "\"" { break }
        s = s + cc
        i = i + 1
      }
      out.push(s)
    }
    i = i + 1
  }
  return out
}

// ── RecordLoader.load — path-jail + 파일 존재 + F1F2 필수필드 디코드 ──────────
// 반환: [status, payload]. status="ok"|"outside"|"notfound"|"decode",
// payload = ok 면 파일내용(JSON), 그 외엔 canonicalPath.
fn _record_load(rel: string) -> array {
  let canonical = _canonical_path(rel)
  let exports = _canonical_path(_exports_root())   // exportsRoot 도 동일 정규화
  // path-jail: canonical 이 exports 로 시작해야 함 (스위프트 hasPrefix).
  if !canonical.starts_with(exports) {
    return ["outside", canonical]
  }
  if !_path_exists(canonical) {
    return ["notfound", canonical]
  }
  let content = to_string(exec("cat " + _shq(canonical) + " 2>/dev/null"))
  // F1F2 필수 최상위/중첩 필드 존재 확인 (스위프트 Codable 필수키 — 누락 시
  // decodeFailed). 중첩 객체는 블록 추출 후 그 안에서 확인.
  let topo = _json_object_block(content, "topology")
  let verd = _json_object_block(content, "verdict")
  let prov = _json_object_block(content, "provenance")
  let req_top = _json_has_key(content, "interface") && _json_has_key(content, "schema_version")
              && _json_has_key(content, "record_id") && _json_has_key(content, "produced_at_utc")
              && _json_has_key(content, "traffic") && topo.len() > 0 && verd.len() > 0 && prov.len() > 0
  let req_topo = _json_has_key(topo, "kind") && _json_has_key(topo, "degree")
              && _json_has_key(topo, "node_count") && _json_has_key(topo, "routing")
  let req_verd = _json_has_key(verd, "f1") && _json_has_key(verd, "f2") && _json_has_key(verd, "rationale")
  let req_prov = _json_has_key(prov, "absorbed") && _json_has_key(prov, "measurement_gate")
              && _json_has_key(prov, "sim_engine") && _json_has_key(prov, "sim_commit_hash")
              && _json_has_key(prov, "gate_failures") && _json_has_key(prov, "consumer_target")
              && _json_has_key(prov, "atlas_cite_block") && _json_has_key(prov, "scope_caveats")
  if !(req_top && req_topo && req_verd && req_prov) {
    return ["decode", canonical]
  }
  return ["ok", content]
}

// ── DemiurgeCLI.show (main.swift §166) ──────────────────────────────────────
fn _cmd_show(rest: array) -> int {
  if len(rest) == 0 {
    eprintln("show: missing <path> argument")
    return 2
  }
  let path = to_string(rest[0])
  let r = _record_load(path)
  let status = to_string(r[0])
  if status == "outside" {
    eprintln("show: Refused (@D g_cockpit_isolation invariant a): path is outside ../exports/**: " + to_string(r[1]))
    return 2
  }
  if status == "notfound" {
    eprintln("show: Record file not found: " + to_string(r[1]))
    return 2
  }
  if status == "decode" {
    eprintln("show: Decode failed (" + to_string(r[1]) + "): F1F2Record 필수 필드 누락")
    return 2
  }
  let src = to_string(r[1])
  let topo = _json_object_block(src, "topology")
  let verd = _json_object_block(src, "verdict")
  let prov = _json_object_block(src, "provenance")
  let commit = _json_string(prov, "sim_commit_hash", 0)
  let mut commit12 = commit
  if commit.len() > 12 { commit12 = commit.substring(0, 12) }
  let gate_fail = _json_string_array(prov, "gate_failures")
  let scope = _json_string_array(prov, "scope_caveats")

  println("record_id:                  " + _json_string(src, "record_id", 0))
  println("interface:                  " + _json_string(src, "interface", 0))
  println("schema_version:             " + _json_string(src, "schema_version", 0))
  println("produced_at_utc:            " + _json_string(src, "produced_at_utc", 0))
  println("topology.kind:              " + _json_string(topo, "kind", 0))
  println("topology.degree:            " + _json_scalar(topo, "degree", 0))
  println("topology.node_count:        " + _json_scalar(topo, "node_count", 0))
  println("topology.routing:           " + _json_string(topo, "routing", 0))
  println("traffic:                    " + _json_string(src, "traffic", 0))
  println("verdict.f1:                 " + _json_string(verd, "f1", 0))
  println("verdict.f2:                 " + _json_string(verd, "f2", 0))
  println("verdict.rationale:          " + _json_string(verd, "rationale", 0))
  println("provenance.measurement_gate:" + _json_string(prov, "measurement_gate", 0))
  println("provenance.absorbed:        " + _json_scalar(prov, "absorbed", 0))
  println("provenance.sim_engine:      " + _json_string(prov, "sim_engine", 0))
  println("provenance.sim_commit:      " + commit12)
  println("provenance.consumer_target: " + _json_string(prov, "consumer_target", 0))
  println("provenance.atlas_cite:      " + _json_string(prov, "atlas_cite_block", 0))
  println("provenance.gate_failures:   " + to_string(len(gate_fail)))
  let mut i = 0
  while i < len(gate_fail) {
    println("  [" + to_string(i) + "] " + to_string(gate_fail[i]))
    i = i + 1
  }
  println("provenance.scope_caveats:   " + to_string(len(scope)))
  i = 0
  while i < len(scope) {
    println("  [" + to_string(i) + "] " + to_string(scope[i]))
    i = i + 1
  }
  return 0
}

// ════════════════════════════════════════════════════════════════════════════
// gate 집계 — 스위프트 main.swift listGates()/gateSummary() + F1F2Record
// .MeasurementGate 이식 (PR-C). 모든 F1F2 stub 을 RecordLoader 로 로드하고,
// 디코드 실패(필수필드 누락)는 스위프트와 동일하게 SILENT SKIP — 그래서
// `ls *.json` 개수보다 집계 대상이 적을 수 있다 (스위프트 byte-identical).
// ════════════════════════════════════════════════════════════════════════════

// F1F2Record.MeasurementGate.allCases — rawValue == displayLabel
// (F1F2Record.swift §61). 렌더/집계 순서도 이 배열이 SSOT.
fn _gate_cases() -> array {
  return ["GATE_OPEN", "GATE_B_PINNED_MET", "GATE_CLOSED_MEASURED", "GATE_FAILED"]
}

// 한 레코드의 (measurement_gate, absorbed) 를 provenance 블록에서 읽는다.
// 반환 [gate, absorbed] — gate="" 면 디코드 실패(스킵 대상).
fn _record_gate_absorbed(content: string) -> array {
  let prov = _json_object_block(content, "provenance")
  let gate = _json_string(prov, "measurement_gate", 0)
  let absorbed = _json_scalar(prov, "absorbed", 0)
  return [gate, absorbed]
}

// `list-gates` — 모든 F1F2 레코드를 gate 별로 묶어 렌더 (main.swift §410).
//   <gate.displayLabel> (<count>):
//     <recordId>  absorbed=<bool>  <stub.title>
// gate.allCases 순서로, 각 gate 의 행은 stub(=파일명) 순서 그대로.
fn _cmd_list_gates() -> int {
  let stubs = _load_f1f2()
  let gates = _gate_cases()
  let mut gi = 0
  while gi < len(gates) {
    let gate = to_string(gates[gi])
    gi = gi + 1
    // 이 gate 에 속하는 행을 stub 순서로 모은다.
    let mut rows = []
    let mut i = 0
    while i < len(stubs) {
      let s = stubs[i]
      i = i + 1
      let r = _record_load(s.path)
      if to_string(r[0]) != "ok" { continue }   // 디코드 실패 SILENT SKIP
      let content = to_string(r[1])
      let ga = _record_gate_absorbed(content)
      if to_string(ga[0]) != gate { continue }
      let rid = _json_string(content, "record_id", 0)
      rows.push(rid + "  absorbed=" + to_string(ga[1]) + "  " + s.title)
    }
    println(gate + " (" + to_string(len(rows)) + "):")
    let mut k = 0
    while k < len(rows) { println("  " + to_string(rows[k])); k = k + 1 }
  }
  return 0
}

// `gate-summary` — gate 별 개수 + absorbed 합계 (main.swift §428).
fn _cmd_gate_summary() -> int {
  let stubs = _load_f1f2()
  let gates = _gate_cases()
  // 각 gate 카운트 + total + absorbed true/false.
  let mut counts = []
  let mut z = 0
  while z < len(gates) { counts.push(0); z = z + 1 }
  let mut total = 0
  let mut atrue = 0
  let mut afalse = 0
  let mut i = 0
  while i < len(stubs) {
    let r = _record_load(stubs[i].path)
    i = i + 1
    if to_string(r[0]) != "ok" { continue }   // 디코드 실패 SILENT SKIP
    let content = to_string(r[1])
    let ga = _record_gate_absorbed(content)
    total = total + 1
    let gate = to_string(ga[0])
    let mut gi = 0
    while gi < len(gates) {
      if to_string(gates[gi]) == gate { counts[gi] = to_int(counts[gi]) + 1 }
      gi = gi + 1
    }
    if to_string(ga[1]) == "true" { atrue = atrue + 1 } else { afalse = afalse + 1 }
  }
  println("total records: " + to_string(total))
  let mut gj = 0
  while gj < len(gates) {
    let label = to_string(gates[gj])
    let n = to_int(counts[gj])
    // pct = n/total*100, 소수1자리 ("%.1f"). total=0 → 0.0.
    let pct = if total > 0 { (to_float(n) / to_float(total)) * 100.0 } else { 0.0 }
    // 22-width label 패딩 (스위프트 max(0, 22 - label.count)).
    let mut pad = ""
    let mut p = label.len()
    while p < 22 { pad = pad + " "; p = p + 1 }
    println("  " + label + pad + to_string(n) + "  (" + _fmt1(pct) + "%)")
    gj = gj + 1
  }
  println("absorbed=true:  " + to_string(atrue))
  println("absorbed=false: " + to_string(afalse))
  return 0
}

// "%.1f" 포맷 — printf 로 위임해 스위프트 String(format:) 와 byte-identical.
fn _fmt1(x: float) -> string {
  return to_string(exec("printf '%.1f' " + _shq(to_string(x)))).trim()
}

// ════════════════════════════════════════════════════════════════════════════
// OperationRegistry + OperabilityAudit + BackendResolver — 스위프트
// OperationRegistry.swift / ComputeBackend.swift / DemiurgeMode + main.swift
// operate()/backend() 이식 (PR-D). expert/owner gate 는 DEMIURGE_EXPERT/
// DEMIURGE_OWNER env 로 동일 분기 (DemiurgeMode.swift). 데이터테이블이 SSOT —
// op 추가/이름변경 = 이 테이블 한 줄 (d4, 스위프트 census 와 일치).
// ════════════════════════════════════════════════════════════════════════════

fn _expert() -> bool { return env("DEMIURGE_EXPERT").len() > 0 }
fn _owner()  -> bool { return env("DEMIURGE_OWNER").len() > 0 }

// Operation row — { reach_glyph, id, tier, verb(canonical|""), target,
// milestone, title }. 스위프트 OperationRegistry.all 17-op census 그대로
// (order = product 12 → owner 5). EDIT HERE = add/rename/remove (d4).
struct OpRow {
  glyph:     string,
  id:        string,
  tier:      string,   // "product" | "owner"
  verb:      string,   // canonical English ("" = nil cross-cutting → "—")
  target:    string,   // "swift" | "hexa" | "substrate"
  milestone: string,
  title:     string
}

fn _op_registry() -> [OpRow] {
  return [
    OpRow { glyph: "✅", id: "project",         tier: "product", verb: "specify",    target: "swift",     milestone: "M15", title: "프로젝트 생성·목록·전환·삭제" },
    OpRow { glyph: "✅", id: "verb-nav",        tier: "product", verb: "",           target: "swift",     milestone: "M15", title: "7단계 앞/뒤 이동" },
    OpRow { glyph: "✅", id: "spec-capture",    tier: "product", verb: "specify",    target: "swift",     milestone: "M15", title: "spec 입력 (재료 선반)" },
    OpRow { glyph: "✅", id: "structure-view",  tier: "product", verb: "structure",  target: "swift",     milestone: "M15", title: "structure 구조 분해 뷰" },
    OpRow { glyph: "✅", id: "design-pick",     tier: "product", verb: "design",     target: "swift",     milestone: "M15", title: "design 옵션 선택" },
    OpRow { glyph: "✅", id: "analyze-loop",    tier: "product", verb: "analyze",    target: "swift",     milestone: "M15", title: "analyze ⟲ 수렴 runner" },
    OpRow { glyph: "✅", id: "synthesize-run",  tier: "product", verb: "synthesize", target: "swift",     milestone: "M15", title: "synthesize 실행 (engine)" },
    OpRow { glyph: "✅", id: "verify",          tier: "product", verb: "verify",     target: "hexa",      milestone: "M16", title: "verify (5-tier 검증)" },
    OpRow { glyph: "✅", id: "record-view",     tier: "product", verb: "verify",     target: "swift",     milestone: "M15", title: "record·gate 열람" },
    OpRow { glyph: "✅", id: "export",          tier: "product", verb: "handoff",    target: "swift",     milestone: "M15", title: "결과 export (usd/stl/record)" },
    OpRow { glyph: "✅", id: "atlas-lookup",    tier: "product", verb: "verify",     target: "hexa",      milestone: "M16", title: "atlas 조회 (읽기)" },
    OpRow { glyph: "✅", id: "compute-backend", tier: "product", verb: "synthesize", target: "substrate", milestone: "M17", title: "compute 백엔드 선택 (로컬/원격)" },
    OpRow { glyph: "🔶", id: "pool-route",      tier: "owner",   verb: "synthesize", target: "substrate", milestone: "M20", title: "pool → 내 호스트 라우팅" },
    OpRow { glyph: "🔶", id: "inbox-handoff",   tier: "owner",   verb: "handoff",    target: "substrate", milestone: "M20", title: "inbox/patches → hexa-lang 핸드오프" },
    OpRow { glyph: "🔶", id: "atlas-register",  tier: "owner",   verb: "verify",     target: "substrate", milestone: "M20", title: "atlas 등록 PR → dancinlab" },
    OpRow { glyph: "🔶", id: "governance",      tier: "owner",   verb: "",           target: "swift",     milestone: "M20", title: "@D 거버넌스 enforcement" },
    OpRow { glyph: "🔶", id: "owner-domain",    tier: "owner",   verb: "specify",    target: "swift",     milestone: "M20", title: "내 연구 domain <NAME>.md 운영" }
  ]
}

// `operate [list|audit]` (main.swift §579). --owner 플래그 또는 DEMIURGE_OWNER
// 면 사장실 op 노출. 첫 비-플래그 토큰이 subcommand (기본 list).
fn _cmd_operate(rest: array) -> int {
  let sub = _operate_first_nonflag(rest)        // firstWhere !hasPrefix "--" ?? "list"
  let want_owner = _backend_owner_flag(rest)    // --owner || DEMIURGE_OWNER
  let ops = _op_registry()
  if sub == "list" {
    // tier.allCases = [product, owner]. 각 tier 의 visible 행만.
    let tiers = ["product", "owner"]
    let mut t = 0
    while t < len(tiers) {
      let tier = to_string(tiers[t])
      t = t + 1
      if tier == "owner" && !want_owner { continue }   // visible() 필터
      // 이 tier 의 행 수.
      let mut rows = []
      let mut k = 0
      while k < len(ops) {
        if ops[k].tier == tier { rows.push(k) }
        k = k + 1
      }
      if len(rows) == 0 { continue }
      let label = if tier == "product" { "🛒 진열대 (external)" } else { "🔒 사장실 (owner)" }
      println(label + " — " + to_string(len(rows)) + ":")
      let mut r = 0
      while r < len(rows) {
        let o = ops[to_int(rows[r])]
        r = r + 1
        if _expert() {
          let verb = if o.verb.len() > 0 { o.verb } else { "—" }
          println("  " + o.glyph + " " + o.id + "  [" + o.target + " · " + verb + " · " + o.milestone + "]  " + o.title)
        } else {
          println("  " + o.glyph + " " + o.title)
        }
      }
      println("")
    }
    if !want_owner {
      println("(🔒 owner ops hidden — set DEMIURGE_OWNER or pass --owner)")
    }
    return 0
  }
  if sub == "audit" {
    // product 행 reach 집계. 현재 census: product 12 = 전부 ✅ (ok).
    // glyph 로 reach 판정 (✅=ok, 🔶=partial, ❌=blocked).
    let mut p_ok = 0
    let mut p_part = 0
    let mut p_block = 0
    let mut o_total = 0
    let mut k = 0
    while k < len(ops) {
      let o = ops[k]
      k = k + 1
      if o.tier == "owner" { o_total = o_total + 1; continue }
      if o.glyph == "✅" { p_ok = p_ok + 1 }
      else if o.glyph == "🔶" { p_part = p_part + 1 }
      else { p_block = p_block + 1 }
    }
    let p_total = p_ok + p_part + p_block
    println("operability audit (CLI+COCKPIT M21):")
    println("  product: " + to_string(p_ok) + " ✅ · " + to_string(p_part) + " 🔶 · " + to_string(p_block) + " ❌  (of " + to_string(p_total) + ")")
    println("  owner:   " + to_string(o_total) + " 🔒 (env-gated)")
    if p_block == 0 && p_part == 0 {
      println("  verdict: ✅ external operability COMPLETE — @goal met")
      return 0
    }
    // pending = product 중 reach != ok → "id(milestone)" join.
    let mut pend = ""
    k = 0
    while k < len(ops) {
      let o = ops[k]
      k = k + 1
      if o.tier == "product" && o.glyph != "✅" {
        if pend.len() > 0 { pend = pend + ", " }
        pend = pend + o.id + "(" + o.milestone + ")"
      }
    }
    println("  verdict: ⏳ pending — " + pend)
    return 1
  }
  eprintln("operate: unknown subcommand '" + sub + "' — use list | audit")
  return 2
}

// 첫 비-플래그 토큰 (스위프트 args.first(where: !hasPrefix "--") ?? "list").
fn _operate_first_nonflag(rest: array) -> string {
  let mut i = 0
  while i < len(rest) {
    let a = to_string(rest[i])
    i = i + 1
    if !a.starts_with("--") { return a }
  }
  return "list"
}

// BackendResolver — local 기본 + DEMIURGE_BACKEND remote + (owner) ~/.pool/
// pool.json hosts. 반환 행 = [id, label, kind, host, owner_bool].
fn _backend_userremote() -> array {
  let spec = env("DEMIURGE_BACKEND").trim()
  if spec.len() == 0 || spec == "local" { return [] }
  let mut host = spec
  if spec.starts_with("ssh:") { host = spec.substring(4, spec.len()) }
  return ["remote:" + host, "원격 백엔드 (" + host + ")", "remote", host, "false"]
}

// active = userRemote ?? local.
fn _backend_active() -> array {
  let r = _backend_userremote()
  if len(r) > 0 { return r }
  return ["local", "내 컴퓨터 (local)", "local", "this machine", "false"]
}

// ~/.pool/pool.json → pool host 행들 (owner only). JSON: { "hosts": [
// { "name", "ssh", "os" }, ... ] }. 부재/파싱실패 = 빈 배열.
fn _backend_poolhosts() -> array {
  let home = to_string(exec("echo $HOME")).trim()
  let path = home + "/.pool/pool.json"
  if !_path_exists(path) { return [] }
  let content = to_string(exec("cat " + _shq(path) + " 2>/dev/null"))
  // hosts 배열 안에서 각 객체의 name/ssh/os 를 순차 추출.
  let mut out = []
  let cp = _find_colon_after_key(content, "hosts", 0)
  if cp < 0 { return out }
  // 각 객체 블록을 "}" 단위로 스캔 — name 키가 나타나는 위치부터.
  let mut i = cp
  while i < content.len() {
    let c = content.substring(i, i + 1)
    if c == "]" { break }
    if c == "{" {
      // 이 객체 블록 추출.
      let mut depth = 0
      let start = i
      while i < content.len() {
        let cc = content.substring(i, i + 1)
        if cc == "{" { depth = depth + 1 }
        else if cc == "}" { depth = depth - 1; if depth == 0 { break } }
        i = i + 1
      }
      let block = content.substring(start, i + 1)
      let name = _json_string(block, "name", 0)
      let ssh  = _json_string(block, "ssh", 0)
      let os   = _json_string(block, "os", 0)
      out.push("pool:" + name + "|pool · " + name + " (" + os + ")|pool|" + ssh + "|true")
    }
    i = i + 1
  }
  return out
}

// `backend [list|current]` (main.swift §543).
fn _cmd_backend(rest: array) -> int {
  let sub = _operate_first_nonflag(rest)   // 동일 firstWhere 의미
  let want_owner = _backend_owner_flag(rest)
  let active = _backend_active()
  if sub == "list" {
    // available = [local] + (userRemote?) + (owner ? poolHosts).
    let mut rows = []
    rows.push(["local", "내 컴퓨터 (local)", "local", "this machine", "false"])
    let ur = _backend_userremote()
    if len(ur) > 0 { rows.push(ur) }
    if want_owner {
      let ph = _backend_poolhosts()
      let mut j = 0
      while j < len(ph) {
        let parts = to_string(ph[j]).split("|")
        rows.push([to_string(parts[0]), to_string(parts[1]), to_string(parts[2]), to_string(parts[3]), to_string(parts[4])])
        j = j + 1
      }
    }
    let active_id = to_string(active[0])
    let mut i = 0
    while i < len(rows) {
      let b = rows[i]
      i = i + 1
      let bid = to_string(b[0])
      let mark = if bid == active_id { "▶" } else { " " }
      let gate = if to_string(b[4]) == "true" { " 🔒" } else { "" }
      if _expert() {
        println(mark + " " + bid + gate + "  [" + to_string(b[2]) + "]  " + to_string(b[1]) + " — " + to_string(b[3]))
      } else {
        println(mark + " " + to_string(b[1]) + gate)
      }
    }
    if !want_owner {
      println("(🔒 owner pool hosts hidden — DEMIURGE_OWNER + ~/.pool/pool.json)")
    }
    println("active: " + active_id + "  (change via DEMIURGE_BACKEND env)")
    return 0
  }
  if sub == "current" {
    println("active backend: " + to_string(active[0]) + " · " + to_string(active[1]) + " — " + to_string(active[3]))
    return 0
  }
  eprintln("backend: unknown subcommand '" + sub + "' — use list | current")
  return 2
}

// --owner 플래그 또는 DEMIURGE_OWNER (스위프트 args.contains||ownerModeEnabled).
fn _backend_owner_flag(rest: array) -> bool {
  if _owner() { return true }
  let mut i = 0
  while i < len(rest) {
    if to_string(rest[i]) == "--owner" { return true }
    i = i + 1
  }
  return false
}

// ════════════════════════════════════════════════════════════════════════════
// ProjectStore + DomainCatalog + Verb — 스위프트 ProjectStore.swift /
// Project.swift(Verb) / Domain.swift(DomainCatalog) + main.swift
// listProjects()/showProject() 이식 (PR-A). 프로젝트 매니페스트는
// ~/Library/Application Support/lab.dancin.demiurge/projects/<uuid>/
// manifest.json (앱-데이터 위치, exports/ 밖 · cockpit 과 동일 SSOT).
// 도메인 메타(label/canvas_mode)는 domains/INDEX.demi 에서 .demi 파싱.
// ════════════════════════════════════════════════════════════════════════════

// Verb 7-spine — koreanLabel + plain (Project.swift). rawValue 0..6.
fn _verb_korean(rv: int) -> string {
  if rv == 0 { return "명세" }
  if rv == 1 { return "구조" }
  if rv == 2 { return "설계" }
  if rv == 3 { return "해석⟲" }
  if rv == 4 { return "합성" }
  if rv == 5 { return "검증" }
  return "인계"
}
fn _verb_plain(rv: int) -> string {
  if rv == 0 { return "무엇을" }
  if rv == 1 { return "어떻게" }
  if rv == 2 { return "설계" }
  if rv == 3 { return "점검" }
  if rv == 4 { return "만들기" }
  if rv == 5 { return "검증" }
  return "넘기기"
}

// projectsRoot = ~/Library/Application Support/lab.dancin.demiurge/projects.
fn _projects_root() -> string {
  let home = to_string(exec("echo $HOME")).trim()
  return home + "/Library/Application Support/lab.dancin.demiurge/projects"
}

// DomainCatalog.domain(for:) — INDEX.demi 의 [<id>] 섹션에서 label/canvas_mode.
// 미등록 키 → label = (key=="general" ? "일반 공학" : key), canvas="cohort".
// 반환 [label, canvasMode].
fn _domain_meta(key: string) -> array {
  let path = _project_root() + "/domains/INDEX.demi"
  if _path_exists(path) {
    // [<key>] 섹션 추출 후 label/canvas_mode 파싱 (DemiParser 동치 · 라인기반).
    // awk: 해당 섹션 헤더부터 다음 헤더 전까지의 라인.
    let body = to_string(exec(
      "awk 'BEGIN{f=0} /^\\[/{ if(f)exit; if($0==\"[" + key + "]\")f=1; next } f{print}' "
      + _shq(path) + " 2>/dev/null"))
    if body.len() > 0 {
      let label = _demi_scalar(body, "label")
      let mut canvas = _demi_scalar(body, "canvas_mode")
      if canvas.len() == 0 { canvas = "cohort" }   // project(): canvas_mode ?? "cohort"
      if label.len() > 0 { return [label, canvas] }
    }
  }
  // 미등록 fallback (DomainCatalog.domain synthetic).
  let label = if key == "general" { "일반 공학" } else { key }
  return [label, "cohort"]
}

// .demi 섹션 본문에서 `key = "value"` 스칼라 추출 (unquote · trailing # 제거).
fn _demi_scalar(body: string, key: string) -> string {
  let raw = to_string(exec(
    "printf '%s' " + _shq(body) + " | grep -E '^[[:space:]]*" + key + "[[:space:]]*=' | head -1"))
  let line = raw.trim()
  if line.len() == 0 { return "" }
  let eq = line.index_of("=")
  if eq < 0 { return "" }
  let mut v = line.substring(eq + 1, line.len()).trim()
  // trailing comment.
  let hash = v.index_of("#")
  if hash >= 0 { v = v.substring(0, hash).trim() }
  // unquote.
  if v.len() >= 2 && v.starts_with("\"") && v.ends_with("\"") {
    v = v.substring(1, v.len() - 1)
  }
  return v
}

// 한 프로젝트 매니페스트 → 필드 맵 (반환 [name, target, domain, currentVerb,
// createdAt, doneVerbs_csv]). 디코드 실패 시 name="".
fn _load_project_manifest(path: string) -> array {
  let content = to_string(exec("cat " + _shq(path) + " 2>/dev/null"))
  if content.len() == 0 { return [""] }
  let name = _json_string(content, "name", 0)
  let target = _json_string(content, "target", 0)
  let domain = _json_string(content, "domain", 0)
  let cv = _json_scalar(content, "currentVerb", 0)
  let created = _json_string(content, "createdAt", 0)
  if name.len() == 0 { return [""] }
  // doneVerbs = [int,...] — `"doneVerbs"` 다음 [ ] 내부에서 정수 토큰 추출.
  let done_csv = _json_int_array_csv(content, "doneVerbs")
  return [name, target, domain, cv, created, done_csv]
}

// "key": [ 1, 2, ... ] → "1,2" CSV (doneVerbs int 배열).
fn _json_int_array_csv(src: string, key: string) -> string {
  let cp = _find_colon_after_key(src, key, 0)
  if cp < 0 { return "" }
  let mut i = cp
  while i < src.len() && src.substring(i, i + 1) != "[" { i = i + 1 }
  if i >= src.len() { return "" }
  i = i + 1
  let mut out = ""
  let mut cur = ""
  while i < src.len() {
    let c = src.substring(i, i + 1)
    i = i + 1
    if c == "]" { break }
    if c >= "0" && c <= "9" { cur = cur + c; continue }
    // 구분자 — 누적된 토큰 flush.
    if cur.len() > 0 { if out.len() > 0 { out = out + "," }; out = out + cur; cur = "" }
  }
  if cur.len() > 0 { if out.len() > 0 { out = out + "," }; out = out + cur }
  return out
}

// 모든 프로젝트 매니페스트 로드 (createdAt 오름차순 정렬 — ProjectStore.loadAll).
// 반환 = [[name,target,domain,cv,created,done], ...].
fn _load_all_projects() -> array {
  let root = _projects_root()
  let mut out = []
  if !_path_exists(root) { return out }
  // <uuid>/manifest.json 목록.
  let listing = to_string(exec(
    "ls -1 " + _shq(root) + " 2>/dev/null"))
  let dirs = listing.split("\n")
  let mut i = 0
  while i < len(dirs) {
    let d = to_string(dirs[i]).trim()
    i = i + 1
    if d.len() == 0 { continue }
    let mp = root + "/" + d + "/manifest.json"
    if !_path_exists(mp) { continue }
    let m = _load_project_manifest(mp)
    if to_string(m[0]).len() == 0 { continue }   // 디코드 실패 SKIP
    out.push(m)
  }
  // createdAt 오름차순 (문자열 ISO8601 비교 = 시간순 동치).
  let mut a = 0
  while a < len(out) {
    let mut b = a + 1
    while b < len(out) {
      if to_string(out[b][4]) < to_string(out[a][4]) {
        let tmp = out[a]; out[a] = out[b]; out[b] = tmp
      }
      b = b + 1
    }
    a = a + 1
  }
  return out
}

// `list-projects` (main.swift §206).
//   projects (<count>):
//     <name>  —  <domain.label> · <cv+1>/7 <verb.koreanLabel>
fn _cmd_list_projects() -> int {
  let ps = _load_all_projects()
  println("projects (" + to_string(len(ps)) + "):")
  let mut i = 0
  while i < len(ps) {
    let p = ps[i]
    i = i + 1
    let meta = _domain_meta(to_string(p[2]))
    let cv = to_int(p[3])
    println("  " + to_string(p[0]) + "  —  " + to_string(meta[0]) + " · " + to_string(cv + 1) + "/7 " + _verb_korean(cv))
  }
  return 0
}

// ISO8601 UTC → Swift Date.description ("YYYY-MM-DD HH:MM:SS +0000").
// "2026-05-29T15:43:10Z" → "2026-05-29 15:43:10 +0000".
fn _date_desc(iso: string) -> string {
  let mut s = iso
  // 소수초가 있으면 (예 ...10.5Z) 정수초로 절단은 하지 않음 — 스위프트 Date
  // description 은 소수초 없을 때 SS 만 출력. 매니페스트는 .iso8601(소수초無).
  // 'T' → ' '.
  let t = s.index_of("T")
  if t >= 0 { s = s.substring(0, t) + " " + s.substring(t + 1, s.len()) }
  // trailing 'Z' 제거.
  if s.ends_with("Z") { s = s.substring(0, s.len() - 1) }
  return s + " +0000"
}

// `show-project <name>` (main.swift §218).
fn _cmd_show_project(rest: array) -> int {
  if len(rest) == 0 {
    eprintln("show-project: missing <name> argument")
    return 2
  }
  let name = to_string(rest[0])
  let ps = _load_all_projects()
  let mut found = -1
  let mut i = 0
  while i < len(ps) {
    if to_string(ps[i][0]) == name { found = i; break }
    i = i + 1
  }
  if found < 0 {
    eprintln("show-project: no project named '" + name + "'")
    return 2
  }
  let p = ps[found]
  let meta = _domain_meta(to_string(p[2]))
  let cv = to_int(p[3])
  // doneVerbs 셋.
  let done = to_string(p[5])
  println("name:        " + to_string(p[0]))
  println("target:      " + to_string(p[1]))
  println("domain:      " + to_string(p[2]) + " (" + to_string(meta[0]) + ")")
  println("canvas_mode: " + to_string(meta[1]))
  println("created_at:  " + _date_desc(to_string(p[4])))
  println("7-verb progress:")
  let mut v = 0
  while v < 7 {
    // state(of:) — done / current / visited / upcoming.
    let mark = if _set_has(done, v) { "[x] done (measured)" }
               else if v == cv { "[>] current" }
               else if v < cv { "[~] visited (unmeasured)" }
               else { "[ ] upcoming" }
    println("  " + to_string(v + 1) + ". " + _verb_korean(v) + " (" + _verb_plain(v) + ")  " + mark)
    v = v + 1
  }
  return 0
}

// doneVerbs CSV 에 rawValue 포함 여부.
fn _set_has(csv: string, rv: int) -> bool {
  if csv.len() == 0 { return false }
  let parts = csv.split(",")
  let mut i = 0
  while i < len(parts) {
    if to_string(parts[i]).trim() == to_string(rv) { return true }
    i = i + 1
  }
  return false
}

// ── verb 핸들러 ──────────────────────────────────────────────────────────────
fn _cmd_version() -> int {
  println("demiurge " + DEMIURGE_CLI_VERSION)
  return 0
}

// `discover <objective> [--verifier <p>] [--rounds N] [--json]` — 8-verb head.
// phanes CLI 로 dispatch 하는 얇은 subprocess 래퍼 (d3 — phanes 가 OUROBOROS
// 루프 소유, demiurge 는 dispatch 만 · d4). 바이너리 위치 resolution:
//   1. $PHANES_BIN  2. /usr/local/bin/phanes  3. /opt/homebrew/bin/phanes
//   4. ~/core/phanes/bin/phanes  (스위프트 discoverCmd 과 동일 순서).
fn _cmd_discover(rest: array) -> int {
  if len(rest) == 0 {
    eprintln("discover: usage — discover <objective> [--verifier <path>] [--rounds N] [--json]")
    return 2
  }
  let home = to_string(exec("echo $HOME")).trim()
  let env_bin = env("PHANES_BIN")
  let mut cands = []
  if env_bin.len() > 0 { cands.push(env_bin) }
  cands.push("/usr/local/bin/phanes")
  cands.push("/opt/homebrew/bin/phanes")
  cands.push(home + "/core/phanes/bin/phanes")
  let mut bin = ""
  let mut i = 0
  while i < len(cands) {
    if _file_exists(to_string(cands[i])) { bin = to_string(cands[i]); break }
    i = i + 1
  }
  if bin == "" {
    eprintln("discover: phanes CLI not found.")
    eprintln("  searched: " + cands.join(", "))
    eprintln("  set PHANES_BIN env var to override.")
    eprintln("  contract expected (phanes-side):")
    eprintln("    phanes discover <objective> [--verifier <path>] [--rounds N] [--json]")
    eprintln("  phanes owns the OUROBOROS loop; demiurge dispatches only (d3/d4).")
    return 2
  }
  // argv 를 그대로 forward (출력 캡처 후 재출력 · 종료코드 전파).
  let mut cmd = _shq(bin) + " discover"
  let mut k = 0
  while k < len(rest) { cmd = cmd + " " + _shq(to_string(rest[k])); k = k + 1 }
  let r = exec_with_status(cmd + " 2>&1")
  let out = to_string(r[0])
  print(out)
  if out.len() > 0 && !out.ends_with("\n") { println("") }
  return r[1]
}

// `atlas <verb> [args]` — hexa atlas SSOT 읽기. READ verb (lookup/stats/hash/
// dump) 는 `hexa atlas` 로 VERBATIM forward. WRITE verb (register/append-
// witness/pr) 은 owner op (사장실 · M20) — DEMIURGE_OWNER 없으면 거부.
fn _cmd_atlas(rest: array) -> int {
  let verb = if len(rest) >= 1 { to_string(rest[0]) } else { "stats" }
  let is_read = verb == "lookup" || verb == "stats" || verb == "hash" || verb == "dump"
  let is_write = verb == "register" || verb == "append-witness" || verb == "pr"
  if is_write {
    let owner = env("DEMIURGE_OWNER")
    if owner.len() == 0 {
      eprintln("atlas: '" + verb + "' = owner op (사장실 · M20). Set DEMIURGE_OWNER to unlock. External read-only: lookup/stats/hash/dump.")
      return 2
    }
  } else if !is_read {
    eprintln("atlas: unknown verb '" + verb + "' — read: lookup/stats/hash/dump · owner write: register/append-witness/pr")
    return 2
  }
  let mut cmd = "hexa atlas"
  let mut k = 0
  while k < len(rest) { cmd = cmd + " " + _shq(to_string(rest[k])); k = k + 1 }
  let r = exec_with_status(cmd + " 2>&1")
  let out = to_string(r[0])
  print(out)
  if out.len() > 0 && !out.ends_with("\n") { println("") }
  return r[1]
}

// `verify <path|id>` | `verify --expr|--fence|rubric ...` — M16.
// --expr/--fence/rubric 은 `hexa verify` 로 VERBATIM forward (verdict 그대로 ·
// @D g5 — demiurge 는 재판정하지 않고 dispatch 만). 바레 <path|id> (provenance/
// claim-gate 일관성) 은 DemiurgeCore RecordLoader 의존 — DemiurgeCore 포팅
// 단계로 연기, 그때까지 스위프트 폴백 센티넬(exit 3).
fn _cmd_verify(rest: array) -> int {
  if len(rest) == 0 {
    eprintln("verify: missing <path|id> argument")
    return 2
  }
  let sub = to_string(rest[0])
  if sub == "--expr" || sub == "--fence" || sub == "rubric" {
    let mut cmd = "hexa verify"
    let mut k = 0
    while k < len(rest) { cmd = cmd + " " + _shq(to_string(rest[k])); k = k + 1 }
    let r = exec_with_status(cmd + " 2>&1")
    let out = to_string(r[0])
    print(out)
    if out.len() > 0 && !out.ends_with("\n") { println("") }
    return r[1]
  }
  // 바레 <path|id> record-consistency — DemiurgeCore 포팅 대기 → 스위프트 폴백.
  eprintln("verify: record-consistency arm (<path|id>) 아직 hexa-native 미이식 — 스위프트 폴백 (DemiurgeCore 포팅 단계).")
  return 3
}

// `owner` — 사장실 status surface (M20). DEMIURGE_OWNER 설정 여부 + gate 되는
// owner-only op 목록. (스위프트는 OperationRegistry manifest 에서 op 목록을
// 읽는다 — 그 manifest 는 DemiurgeCore 포팅 단계로 연기; 여기선 status 만.)
fn _cmd_owner() -> int {
  let on = env("DEMIURGE_OWNER").len() > 0
  if on {
    println("owner-mode (사장실): ✅ unlocked (DEMIURGE_OWNER)")
  } else {
    println("owner-mode (사장실): 🔒 locked")
    println("  → unlock: DEMIURGE_OWNER=1 demiurge <cmd>  (외부 사용자에겐 비노출)")
  }
  return 0
}

// ── generic dispatch ─────────────────────────────────────────────────────────
//
// verb 이름으로 직접 분기하지 않는다: (1) 레지스트리 순회로 verb 존재/이식
// 여부를 확인하고 (2) 이식된 verb 만 단일 dispatch 지점으로 보낸다. 미이식
// verb 는 스위프트 폴백을 알리는 종료코드 3 (bin/demiurge 가 이를 보고
// 스위프트로 위임 — parity 전까지). 미지의 verb → 통일된 종료코드 2.
fn _lookup(reg: [VerbSpec], name: string) -> int {
  let mut i = 0
  while i < len(reg) {
    if reg[i].name == name { return i }
    i = i + 1
  }
  return -1
}

fn _dispatch(verb: string, rest: array) -> int {
  // 단일 dispatch 지점 — 이식된 verb 만. (이식되며 한 줄씩 늘어난다.)
  if verb == "version"  { return _cmd_version() }
  if verb == "list-all"       { return _cmd_list_all() }
  if verb == "list-records"   { return _list_kind("f1f2") }
  if verb == "list-decisions" { return _list_kind("decision") }
  if verb == "list-rfcs"      { return _list_kind("rfc") }
  if verb == "list-domains"   { return _list_kind("domain") }
  if verb == "show"           { return _cmd_show(rest) }
  if verb == "list-projects"  { return _cmd_list_projects() }
  if verb == "show-project"   { return _cmd_show_project(rest) }
  if verb == "list-gates"     { return _cmd_list_gates() }
  if verb == "gate-summary"   { return _cmd_gate_summary() }
  if verb == "operate"        { return _cmd_operate(rest) }
  if verb == "backend"        { return _cmd_backend(rest) }
  if verb == "discover" { return _cmd_discover(rest) }
  if verb == "atlas"    { return _cmd_atlas(rest) }
  if verb == "verify"   { return _cmd_verify(rest) }
  if verb == "owner"    { return _cmd_owner() }
  // 도달 불가 (generic 층이 ported 플래그로 이미 거른다).
  return 3
}

fn main() {
  let a = _slice_args()
  if len(a) == 0 {
    _usage()
    exit(0)
  }
  let verb0 = to_string(a[0])
  // --version / -v / --help / -h 는 스위프트 표면과 동일하게 최상위 처리.
  if verb0 == "--version" || verb0 == "-v" {
    exit(_cmd_version())
  }
  if verb0 == "--help" || verb0 == "-h" || verb0 == "help" {
    _usage()
    exit(0)
  }
  let reg = _verb_registry()
  let idx = _lookup(reg, verb0)
  if idx < 0 {
    eprintln("unknown subcommand: " + verb0)
    _usage()
    exit(2)
  }
  let spec = reg[idx]
  if !spec.ported {
    // 미이식 — bin/demiurge 가 스위프트 CLI 로 폴백하도록 종료코드 3.
    eprintln("demiurge cli: '" + verb0 + "' 아직 hexa-native 미이식 — 스위프트 폴백 (parity 진행 중).")
    exit(3)
  }
  let mut rest = []
  let mut i = 1
  while i < len(a) { rest.push(to_string(a[i])); i = i + 1 }
  exit(_dispatch(verb0, rest))
}
